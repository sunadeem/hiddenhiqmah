[{"id": 6091, "number": 1, "key": "94:1", "textAr": "أَلَمْ نَشْرَحْ لَكَ صَدْرَكَ", "textEn": "Did We not expand for you, [O Muḥammad], your breast?", "juz": 30, "page": 596, "hizb": 60, "textTranslit": "Alam nashrah laka sadrak"}, {"id": 6092, "number": 2, "key": "94:2", "textAr": "وَوَضَعْنَا عَنكَ وِزْرَكَ", "textEn": "And We removed from you your burden", "juz": 30, "page": 596, "hizb": 60, "textTranslit": "Wa wa d'ana 'anka wizrak"}, {"id": 6093, "number": 3, "key": "94:3", "textAr": "ٱلَّذِىٓ أَنقَضَ ظَهْرَكَ", "textEn": "Which had weighed upon your back", "juz": 30, "page": 596, "hizb": 60, "textTranslit": "Allazee anqada zahrak"}, {"id": 6094, "number": 4, "key": "94:4", "textAr": "وَرَفَعْنَا لَكَ ذِكْرَكَ", "textEn": "And raised high for you your repute.", "juz": 30, "page": 596, "hizb": 60, "textTranslit": "Wa raf 'ana laka zikrak"}, {"id": 6095, "number": 5, "key": "94:5", "textAr": "فَإِنَّ مَعَ ٱلْعُسْرِ يُسْرًا", "textEn": "For indeed, with hardship [will be] ease [i.e., relief].", "juz": 30, "page": 596, "hizb": 60, "textTranslit": "Fa inna ma'al usri yusra"}, {"id": 6096, "number": 6, "key": "94:6", "textAr": "إِنَّ مَعَ ٱلْعُسْرِ يُسْرًا", "textEn": "Indeed, with hardship [will be] ease.", "juz": 30, "page": 596, "hizb": 60, "textTranslit": "Inna ma'al 'usri yusra"}, {"id": 6097, "number": 7, "key": "94:7", "textAr": "فَإِذَا فَرَغْتَ فَٱنصَبْ", "textEn": "So when you have finished [your duties], then stand up [for worship].", "juz": 30, "page": 596, "hizb": 60, "textTranslit": "Fa iza faragh ta fansab"}, {"id": 6098, "number": 8, "key": "94:8", "textAr": "وَإِلَىٰ رَبِّكَ فَٱرْغَب", "textEn": "And to your Lord direct [your] longing.", "juz": 30, "page": 596, "hizb": 60, "textTranslit": "Wa ilaa rabbika far ghab"}]