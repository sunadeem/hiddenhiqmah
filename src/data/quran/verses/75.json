[{"id": 5552, "number": 1, "key": "75:1", "textAr": "لَآ أُقْسِمُ بِيَوْمِ ٱلْقِيَـٰمَةِ", "textEn": "I swear by the Day of Resurrection", "juz": 29, "page": 577, "hizb": 58, "textTranslit": "Laaa uqsimu bi yawmil qiyaamah"}, {"id": 5553, "number": 2, "key": "75:2", "textAr": "وَلَآ أُقْسِمُ بِٱلنَّفْسِ ٱللَّوَّامَةِ", "textEn": "And I swear by the reproaching soul [to the certainty of resurrection].", "juz": 29, "page": 577, "hizb": 58, "textTranslit": "Wa laaa uqsimu bin nafsil lawwaamah"}, {"id": 5554, "number": 3, "key": "75:3", "textAr": "أَيَحْسَبُ ٱلْإِنسَـٰنُ أَلَّن نَّجْمَعَ عِظَامَهُۥ", "textEn": "Does man think that We will not assemble his bones?", "juz": 29, "page": 577, "hizb": 58, "textTranslit": "Ayahsabul insaanu al lan najm'a 'izaamah"}, {"id": 5555, "number": 4, "key": "75:4", "textAr": "بَلَىٰ قَـٰدِرِينَ عَلَىٰٓ أَن نُّسَوِّىَ بَنَانَهُۥ", "textEn": "Yes. [We are] Able [even] to proportion his fingertips.", "juz": 29, "page": 577, "hizb": 58, "textTranslit": "Balaa qaadireena 'alaaa an nusawwiya banaanah"}, {"id": 5556, "number": 5, "key": "75:5", "textAr": "بَلْ يُرِيدُ ٱلْإِنسَـٰنُ لِيَفْجُرَ أَمَامَهُۥ", "textEn": "But man desires to continue in sin.", "juz": 29, "page": 577, "hizb": 58, "textTranslit": "Bal yureedul insaanu liyafjura amaamah"}, {"id": 5557, "number": 6, "key": "75:6", "textAr": "يَسْـَٔلُ أَيَّانَ يَوْمُ ٱلْقِيَـٰمَةِ", "textEn": "He asks, \"When is the Day of Resurrection?\"", "juz": 29, "page": 577, "hizb": 58, "textTranslit": "Yas'alu ayyyaana yawmul qiyaamah"}, {"id": 5558, "number": 7, "key": "75:7", "textAr": "فَإِذَا بَرِقَ ٱلْبَصَرُ", "textEn": "So when vision is dazzled.", "juz": 29, "page": 577, "hizb": 58, "textTranslit": "Fa izaa bariqal basar"}, {"id": 5559, "number": 8, "key": "75:8", "textAr": "وَخَسَفَ ٱلْقَمَرُ", "textEn": "And the moon darkens.", "juz": 29, "page": 577, "hizb": 58, "textTranslit": "We khasafal qamar"}, {"id": 5560, "number": 9, "key": "75:9", "textAr": "وَجُمِعَ ٱلشَّمْسُ وَٱلْقَمَرُ", "textEn": "And the sun and the moon are joined,", "juz": 29, "page": 577, "hizb": 58, "textTranslit": "Wa jumi'ash shamusu wal qamar"}, {"id": 5561, "number": 10, "key": "75:10", "textAr": "يَقُولُ ٱلْإِنسَـٰنُ يَوْمَئِذٍ أَيْنَ ٱلْمَفَرُّ", "textEn": "Man will say on that Day, \"Where is the [place of] escape?\"", "juz": 29, "page": 577, "hizb": 58, "textTranslit": "Yaqoolul insaanu yaw ma 'izin aynal mafarr"}, {"id": 5562, "number": 11, "key": "75:11", "textAr": "كَلَّا لَا وَزَرَ", "textEn": "No! There is no refuge.", "juz": 29, "page": 577, "hizb": 58, "textTranslit": "Kallaa laa wazar"}, {"id": 5563, "number": 12, "key": "75:12", "textAr": "إِلَىٰ رَبِّكَ يَوْمَئِذٍ ٱلْمُسْتَقَرُّ", "textEn": "To your Lord, that Day, is the [place of] permanence.", "juz": 29, "page": 577, "hizb": 58, "textTranslit": "Ilaa rabbika yawma 'izinil mustaqarr"}, {"id": 5564, "number": 13, "key": "75:13", "textAr": "يُنَبَّؤُا۟ ٱلْإِنسَـٰنُ يَوْمَئِذٍۭ بِمَا قَدَّمَ وَأَخَّرَ", "textEn": "Man will be informed that Day of what he sent ahead and kept back.", "juz": 29, "page": 577, "hizb": 58, "textTranslit": "Yunabba 'ul insaanu yawma 'izim bimaa qaddama wa akhkhar"}, {"id": 5565, "number": 14, "key": "75:14", "textAr": "بَلِ ٱلْإِنسَـٰنُ عَلَىٰ نَفْسِهِۦ بَصِيرَةٌ", "textEn": "Rather, man, against himself, will be a witness,", "juz": 29, "page": 577, "hizb": 58, "textTranslit": "Balil insaanu 'alaa nafsihee baseerah"}, {"id": 5566, "number": 15, "key": "75:15", "textAr": "وَلَوْ أَلْقَىٰ مَعَاذِيرَهُۥ", "textEn": "Even if he presents his excuses.", "juz": 29, "page": 577, "hizb": 58, "textTranslit": "Wa law alqaa ma'aazeerah"}, {"id": 5567, "number": 16, "key": "75:16", "textAr": "لَا تُحَرِّكْ بِهِۦ لِسَانَكَ لِتَعْجَلَ بِهِۦٓ", "textEn": "Move not your tongue with it, [O Muḥammad], to hasten with it [i.e., recitation of the Qur’ān].", "juz": 29, "page": 577, "hizb": 58, "textTranslit": "Laa tuharrik bihee lisaa naka lita'jala bih"}, {"id": 5568, "number": 17, "key": "75:17", "textAr": "إِنَّ عَلَيْنَا جَمْعَهُۥ وَقُرْءَانَهُۥ", "textEn": "Indeed, upon Us is its collection [in your heart] and [to make possible] its recitation.", "juz": 29, "page": 577, "hizb": 58, "textTranslit": "Inna 'alainaa jam'ahoo wa qur aanah"}, {"id": 5569, "number": 18, "key": "75:18", "textAr": "فَإِذَا قَرَأْنَـٰهُ فَٱتَّبِعْ قُرْءَانَهُۥ", "textEn": "So when We have recited it [through Gabriel], then follow its recitation.", "juz": 29, "page": 577, "hizb": 58, "textTranslit": "Fa izaa qaraanaahu fattabi' qur aanah"}, {"id": 5570, "number": 19, "key": "75:19", "textAr": "ثُمَّ إِنَّ عَلَيْنَا بَيَانَهُۥ", "textEn": "Then upon Us is its clarification [to you].", "juz": 29, "page": 577, "hizb": 58, "textTranslit": "Summa inna 'alainaa bayaanah"}, {"id": 5571, "number": 20, "key": "75:20", "textAr": "كَلَّا بَلْ تُحِبُّونَ ٱلْعَاجِلَةَ", "textEn": "No! But you [i.e., mankind] love the immediate", "juz": 29, "page": 578, "hizb": 58, "textTranslit": "Kallaa bal tuhibboonal 'aajilah"}, {"id": 5572, "number": 21, "key": "75:21", "textAr": "وَتَذَرُونَ ٱلْـَٔاخِرَةَ", "textEn": "And leave [i.e., neglect] the Hereafter.", "juz": 29, "page": 578, "hizb": 58, "textTranslit": "Wa tazaroonal Aakhirah"}, {"id": 5573, "number": 22, "key": "75:22", "textAr": "وُجُوهٌ يَوْمَئِذٍ نَّاضِرَةٌ", "textEn": "[Some] faces, that Day, will be radiant,", "juz": 29, "page": 578, "hizb": 58, "textTranslit": "Wujoohuny yawma 'izin naadirah"}, {"id": 5574, "number": 23, "key": "75:23", "textAr": "إِلَىٰ رَبِّهَا نَاظِرَةٌ", "textEn": "Looking at their Lord.", "juz": 29, "page": 578, "hizb": 58, "textTranslit": "Ilaa rabbihaa naazirah"}, {"id": 5575, "number": 24, "key": "75:24", "textAr": "وَوُجُوهٌ يَوْمَئِذٍۭ بَاسِرَةٌ", "textEn": "And [some] faces, that Day, will be contorted,", "juz": 29, "page": 578, "hizb": 58, "textTranslit": "Wa wujoohuny yawma 'izim baasirah"}, {"id": 5576, "number": 25, "key": "75:25", "textAr": "تَظُنُّ أَن يُفْعَلَ بِهَا فَاقِرَةٌ", "textEn": "Expecting that there will be done to them [something] backbreaking.", "juz": 29, "page": 578, "hizb": 58, "textTranslit": "Tazunnu any yuf'ala bihaa faaqirah"}, {"id": 5577, "number": 26, "key": "75:26", "textAr": "كَلَّآ إِذَا بَلَغَتِ ٱلتَّرَاقِىَ", "textEn": "No! When it [i.e., the soul] has reached the collar bones", "juz": 29, "page": 578, "hizb": 58, "textTranslit": "Kallaaa izaa balaghatit taraaqee"}, {"id": 5578, "number": 27, "key": "75:27", "textAr": "وَقِيلَ مَنْ ۜ رَاقٍ", "textEn": "And it is said, \"Who will cure [him]?\"", "juz": 29, "page": 578, "hizb": 58, "textTranslit": "Wa qeela man raaq"}, {"id": 5579, "number": 28, "key": "75:28", "textAr": "وَظَنَّ أَنَّهُ ٱلْفِرَاقُ", "textEn": "And he [i.e., the dying one] is certain that it is the [time of] separation", "juz": 29, "page": 578, "hizb": 58, "textTranslit": "Wa zanna annahul firaaq"}, {"id": 5580, "number": 29, "key": "75:29", "textAr": "وَٱلْتَفَّتِ ٱلسَّاقُ بِٱلسَّاقِ", "textEn": "And the leg is wound about the leg,", "juz": 29, "page": 578, "hizb": 58, "textTranslit": "Waltaffatis saaqu bissaaq"}, {"id": 5581, "number": 30, "key": "75:30", "textAr": "إِلَىٰ رَبِّكَ يَوْمَئِذٍ ٱلْمَسَاقُ", "textEn": "To your Lord, that Day, will be the procession.", "juz": 29, "page": 578, "hizb": 58, "textTranslit": "Ilaa rabbika yawma'izinil masaaq"}, {"id": 5582, "number": 31, "key": "75:31", "textAr": "فَلَا صَدَّقَ وَلَا صَلَّىٰ", "textEn": "And he [i.e., the disbeliever] had not believed, nor had he prayed.", "juz": 29, "page": 578, "hizb": 58, "textTranslit": "Falaa saddaqa wa laa sallaa"}, {"id": 5583, "number": 32, "key": "75:32", "textAr": "وَلَـٰكِن كَذَّبَ وَتَوَلَّىٰ", "textEn": "But [instead], he denied and turned away.", "juz": 29, "page": 578, "hizb": 58, "textTranslit": "Wa laakin kazzaba wa tawalla"}, {"id": 5584, "number": 33, "key": "75:33", "textAr": "ثُمَّ ذَهَبَ إِلَىٰٓ أَهْلِهِۦ يَتَمَطَّىٰٓ", "textEn": "And then he went to his people, swaggering [in pride].", "juz": 29, "page": 578, "hizb": 58, "textTranslit": "Summa zahaba ilaaa ahlihee yatamatta"}, {"id": 5585, "number": 34, "key": "75:34", "textAr": "أَوْلَىٰ لَكَ فَأَوْلَىٰ", "textEn": "Woe to you, and woe!", "juz": 29, "page": 578, "hizb": 58, "textTranslit": "Awlaa laka fa awlaa"}, {"id": 5586, "number": 35, "key": "75:35", "textAr": "ثُمَّ أَوْلَىٰ لَكَ فَأَوْلَىٰٓ", "textEn": "Then woe to you, and woe!", "juz": 29, "page": 578, "hizb": 58, "textTranslit": "Summa awlaa laka fa awla"}, {"id": 5587, "number": 36, "key": "75:36", "textAr": "أَيَحْسَبُ ٱلْإِنسَـٰنُ أَن يُتْرَكَ سُدًى", "textEn": "Does man think that he will be left neglected?", "juz": 29, "page": 578, "hizb": 58, "textTranslit": "Ayahsabul insaanu anyytraka sudaa"}, {"id": 5588, "number": 37, "key": "75:37", "textAr": "أَلَمْ يَكُ نُطْفَةً مِّن مَّنِىٍّ يُمْنَىٰ", "textEn": "Had he not been a sperm from semen emitted?", "juz": 29, "page": 578, "hizb": 58, "textTranslit": "Alam yaku nutfatam mim maniyyiny yumnaa"}, {"id": 5589, "number": 38, "key": "75:38", "textAr": "ثُمَّ كَانَ عَلَقَةً فَخَلَقَ فَسَوَّىٰ", "textEn": "Then he was a clinging clot, and [Allāh] created [his form] and proportioned [him]", "juz": 29, "page": 578, "hizb": 58, "textTranslit": "Summa kaana 'alaqata fakhalaq fasawwaa"}, {"id": 5590, "number": 39, "key": "75:39", "textAr": "فَجَعَلَ مِنْهُ ٱلزَّوْجَيْنِ ٱلذَّكَرَ وَٱلْأُنثَىٰٓ", "textEn": "And made of him two mates, the male and the female.", "juz": 29, "page": 578, "hizb": 58, "textTranslit": "Faja'ala minhuz zawjayniz zakara wal unsaa"}, {"id": 5591, "number": 40, "key": "75:40", "textAr": "أَلَيْسَ ذَٰلِكَ بِقَـٰدِرٍ عَلَىٰٓ أَن يُحْـِۧىَ ٱلْمَوْتَىٰ", "textEn": "Is not that [Creator] Able to give life to the dead?", "juz": 29, "page": 578, "hizb": 58, "textTranslit": "Alaisa zaalika biqaadirin 'alaaa any yuhyiyal mawtaa"}]