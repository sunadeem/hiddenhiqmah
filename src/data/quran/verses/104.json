[
  {
    "id": 6180,
    "number": 1,
    "key": "104:1",
    "textAr": "وَيْلٌ لِّكُلِّ هُمَزَةٍ لُّمَزَةٍ",
    "textEn": "Woe to every scorner and mocker",
    "juz": 30,
    "page": 601,
    "hizb": 60
  },
  {
    "id": 6181,
    "number": 2,
    "key": "104:2",
    "textAr": "ٱلَّذِى جَمَعَ مَالًا وَعَدَّدَهُۥ",
    "textEn": "Who collects wealth and [continuously] counts it.",
    "juz": 30,
    "page": 601,
    "hizb": 60
  },
  {
    "id": 6182,
    "number": 3,
    "key": "104:3",
    "textAr": "يَحْسَبُ أَنَّ مَالَهُۥٓ أَخْلَدَهُۥ",
    "textEn": "He thinks that his wealth will make him immortal.",
    "juz": 30,
    "page": 601,
    "hizb": 60
  },
  {
    "id": 6183,
    "number": 4,
    "key": "104:4",
    "textAr": "كَلَّا ۖ لَيُنۢبَذَنَّ فِى ٱلْحُطَمَةِ",
    "textEn": "No! He will surely be thrown into the Crusher.",
    "juz": 30,
    "page": 601,
    "hizb": 60
  },
  {
    "id": 6184,
    "number": 5,
    "key": "104:5",
    "textAr": "وَمَآ أَدْرَىٰكَ مَا ٱلْحُطَمَةُ",
    "textEn": "And what can make you know what is the Crusher?",
    "juz": 30,
    "page": 601,
    "hizb": 60
  },
  {
    "id": 6185,
    "number": 6,
    "key": "104:6",
    "textAr": "نَارُ ٱللَّهِ ٱلْمُوقَدَةُ",
    "textEn": "It is the fire of Allāh, [eternally] fueled,",
    "juz": 30,
    "page": 601,
    "hizb": 60
  },
  {
    "id": 6186,
    "number": 7,
    "key": "104:7",
    "textAr": "ٱلَّتِى تَطَّلِعُ عَلَى ٱلْأَفْـِٔدَةِ",
    "textEn": "Which mounts directed at the hearts.",
    "juz": 30,
    "page": 601,
    "hizb": 60
  },
  {
    "id": 6187,
    "number": 8,
    "key": "104:8",
    "textAr": "إِنَّهَا عَلَيْهِم مُّؤْصَدَةٌ",
    "textEn": "Indeed, it [i.e., Hellfire] will be closed down upon them",
    "juz": 30,
    "page": 601,
    "hizb": 60
  },
  {
    "id": 6188,
    "number": 9,
    "key": "104:9",
    "textAr": "فِى عَمَدٍ مُّمَدَّدَةٍۭ",
    "textEn": "In extended columns.",
    "juz": 30,
    "page": 601,
    "hizb": 60
  }
]