[
  {
    "id": 5968,
    "number": 1,
    "key": "88:1",
    "textAr": "هَلْ أَتَىٰكَ حَدِيثُ ٱلْغَـٰشِيَةِ",
    "textEn": "Has there reached you the report of the Overwhelming [event]?",
    "juz": 30,
    "page": 592,
    "hizb": 60
  },
  {
    "id": 5969,
    "number": 2,
    "key": "88:2",
    "textAr": "وُجُوهٌ يَوْمَئِذٍ خَـٰشِعَةٌ",
    "textEn": "[Some] faces, that Day, will be humbled,",
    "juz": 30,
    "page": 592,
    "hizb": 60
  },
  {
    "id": 5970,
    "number": 3,
    "key": "88:3",
    "textAr": "عَامِلَةٌ نَّاصِبَةٌ",
    "textEn": "Working [hard] and exhausted.",
    "juz": 30,
    "page": 592,
    "hizb": 60
  },
  {
    "id": 5971,
    "number": 4,
    "key": "88:4",
    "textAr": "تَصْلَىٰ نَارًا حَامِيَةً",
    "textEn": "They will [enter to] burn in an intensely hot Fire.",
    "juz": 30,
    "page": 592,
    "hizb": 60
  },
  {
    "id": 5972,
    "number": 5,
    "key": "88:5",
    "textAr": "تُسْقَىٰ مِنْ عَيْنٍ ءَانِيَةٍ",
    "textEn": "They will be given drink from a boiling spring.",
    "juz": 30,
    "page": 592,
    "hizb": 60
  },
  {
    "id": 5973,
    "number": 6,
    "key": "88:6",
    "textAr": "لَّيْسَ لَهُمْ طَعَامٌ إِلَّا مِن ضَرِيعٍ",
    "textEn": "For them there will be no food except from a poisonous, thorny plant",
    "juz": 30,
    "page": 592,
    "hizb": 60
  },
  {
    "id": 5974,
    "number": 7,
    "key": "88:7",
    "textAr": "لَّا يُسْمِنُ وَلَا يُغْنِى مِن جُوعٍ",
    "textEn": "Which neither nourishes nor avails against hunger.",
    "juz": 30,
    "page": 592,
    "hizb": 60
  },
  {
    "id": 5975,
    "number": 8,
    "key": "88:8",
    "textAr": "وُجُوهٌ يَوْمَئِذٍ نَّاعِمَةٌ",
    "textEn": "[Other] faces, that Day, will show pleasure.",
    "juz": 30,
    "page": 592,
    "hizb": 60
  },
  {
    "id": 5976,
    "number": 9,
    "key": "88:9",
    "textAr": "لِّسَعْيِهَا رَاضِيَةٌ",
    "textEn": "With their effort [they are] satisfied",
    "juz": 30,
    "page": 592,
    "hizb": 60
  },
  {
    "id": 5977,
    "number": 10,
    "key": "88:10",
    "textAr": "فِى جَنَّةٍ عَالِيَةٍ",
    "textEn": "In an elevated garden,",
    "juz": 30,
    "page": 592,
    "hizb": 60
  },
  {
    "id": 5978,
    "number": 11,
    "key": "88:11",
    "textAr": "لَّا تَسْمَعُ فِيهَا لَـٰغِيَةً",
    "textEn": "Wherein they will hear no unsuitable speech.",
    "juz": 30,
    "page": 592,
    "hizb": 60
  },
  {
    "id": 5979,
    "number": 12,
    "key": "88:12",
    "textAr": "فِيهَا عَيْنٌ جَارِيَةٌ",
    "textEn": "Within it is a flowing spring.",
    "juz": 30,
    "page": 592,
    "hizb": 60
  },
  {
    "id": 5980,
    "number": 13,
    "key": "88:13",
    "textAr": "فِيهَا سُرُرٌ مَّرْفُوعَةٌ",
    "textEn": "Within it are couches raised high",
    "juz": 30,
    "page": 592,
    "hizb": 60
  },
  {
    "id": 5981,
    "number": 14,
    "key": "88:14",
    "textAr": "وَأَكْوَابٌ مَّوْضُوعَةٌ",
    "textEn": "And cups put in place",
    "juz": 30,
    "page": 592,
    "hizb": 60
  },
  {
    "id": 5982,
    "number": 15,
    "key": "88:15",
    "textAr": "وَنَمَارِقُ مَصْفُوفَةٌ",
    "textEn": "And cushions lined up",
    "juz": 30,
    "page": 592,
    "hizb": 60
  },
  {
    "id": 5983,
    "number": 16,
    "key": "88:16",
    "textAr": "وَزَرَابِىُّ مَبْثُوثَةٌ",
    "textEn": "And carpets spread around.",
    "juz": 30,
    "page": 592,
    "hizb": 60
  },
  {
    "id": 5984,
    "number": 17,
    "key": "88:17",
    "textAr": "أَفَلَا يَنظُرُونَ إِلَى ٱلْإِبِلِ كَيْفَ خُلِقَتْ",
    "textEn": "Then do they not look at the camels - how they are created?",
    "juz": 30,
    "page": 592,
    "hizb": 60
  },
  {
    "id": 5985,
    "number": 18,
    "key": "88:18",
    "textAr": "وَإِلَى ٱلسَّمَآءِ كَيْفَ رُفِعَتْ",
    "textEn": "And at the sky - how it is raised?",
    "juz": 30,
    "page": 592,
    "hizb": 60
  },
  {
    "id": 5986,
    "number": 19,
    "key": "88:19",
    "textAr": "وَإِلَى ٱلْجِبَالِ كَيْفَ نُصِبَتْ",
    "textEn": "And at the mountains - how they are erected?",
    "juz": 30,
    "page": 592,
    "hizb": 60
  },
  {
    "id": 5987,
    "number": 20,
    "key": "88:20",
    "textAr": "وَإِلَى ٱلْأَرْضِ كَيْفَ سُطِحَتْ",
    "textEn": "And at the earth - how it is spread out?",
    "juz": 30,
    "page": 592,
    "hizb": 60
  },
  {
    "id": 5988,
    "number": 21,
    "key": "88:21",
    "textAr": "فَذَكِّرْ إِنَّمَآ أَنتَ مُذَكِّرٌ",
    "textEn": "So remind, [O Muḥammad]; you are only a reminder.",
    "juz": 30,
    "page": 592,
    "hizb": 60
  },
  {
    "id": 5989,
    "number": 22,
    "key": "88:22",
    "textAr": "لَّسْتَ عَلَيْهِم بِمُصَيْطِرٍ",
    "textEn": "You are not over them a controller.",
    "juz": 30,
    "page": 592,
    "hizb": 60
  },
  {
    "id": 5990,
    "number": 23,
    "key": "88:23",
    "textAr": "إِلَّا مَن تَوَلَّىٰ وَكَفَرَ",
    "textEn": "However, he who turns away and disbelieves",
    "juz": 30,
    "page": 592,
    "hizb": 60
  },
  {
    "id": 5991,
    "number": 24,
    "key": "88:24",
    "textAr": "فَيُعَذِّبُهُ ٱللَّهُ ٱلْعَذَابَ ٱلْأَكْبَرَ",
    "textEn": "Then Allāh will punish him with the greatest punishment.",
    "juz": 30,
    "page": 592,
    "hizb": 60
  },
  {
    "id": 5992,
    "number": 25,
    "key": "88:25",
    "textAr": "إِنَّ إِلَيْنَآ إِيَابَهُمْ",
    "textEn": "Indeed, to Us is their return.",
    "juz": 30,
    "page": 592,
    "hizb": 60
  },
  {
    "id": 5993,
    "number": 26,
    "key": "88:26",
    "textAr": "ثُمَّ إِنَّ عَلَيْنَا حِسَابَهُم",
    "textEn": "Then indeed, upon Us is their account.",
    "juz": 30,
    "page": 592,
    "hizb": 60
  }
]