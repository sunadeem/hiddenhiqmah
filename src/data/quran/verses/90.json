[
  {
    "id": 6024,
    "number": 1,
    "key": "90:1",
    "textAr": "لَآ أُقْسِمُ بِهَـٰذَا ٱلْبَلَدِ",
    "textEn": "I swear by this city [i.e., Makkah]",
    "juz": 30,
    "page": 594,
    "hizb": 60
  },
  {
    "id": 6025,
    "number": 2,
    "key": "90:2",
    "textAr": "وَأَنتَ حِلٌّۢ بِهَـٰذَا ٱلْبَلَدِ",
    "textEn": "And you, [O Muḥammad], are free of restriction in this city",
    "juz": 30,
    "page": 594,
    "hizb": 60
  },
  {
    "id": 6026,
    "number": 3,
    "key": "90:3",
    "textAr": "وَوَالِدٍ وَمَا وَلَدَ",
    "textEn": "And [by] the father and that which was born [of him],",
    "juz": 30,
    "page": 594,
    "hizb": 60
  },
  {
    "id": 6027,
    "number": 4,
    "key": "90:4",
    "textAr": "لَقَدْ خَلَقْنَا ٱلْإِنسَـٰنَ فِى كَبَدٍ",
    "textEn": "We have certainly created man into hardship.",
    "juz": 30,
    "page": 594,
    "hizb": 60
  },
  {
    "id": 6028,
    "number": 5,
    "key": "90:5",
    "textAr": "أَيَحْسَبُ أَن لَّن يَقْدِرَ عَلَيْهِ أَحَدٌ",
    "textEn": "Does he think that never will anyone overcome him?",
    "juz": 30,
    "page": 594,
    "hizb": 60
  },
  {
    "id": 6029,
    "number": 6,
    "key": "90:6",
    "textAr": "يَقُولُ أَهْلَكْتُ مَالًا لُّبَدًا",
    "textEn": "He says, \"I have spent wealth in abundance.\"",
    "juz": 30,
    "page": 594,
    "hizb": 60
  },
  {
    "id": 6030,
    "number": 7,
    "key": "90:7",
    "textAr": "أَيَحْسَبُ أَن لَّمْ يَرَهُۥٓ أَحَدٌ",
    "textEn": "Does he think that no one has seen him?",
    "juz": 30,
    "page": 594,
    "hizb": 60
  },
  {
    "id": 6031,
    "number": 8,
    "key": "90:8",
    "textAr": "أَلَمْ نَجْعَل لَّهُۥ عَيْنَيْنِ",
    "textEn": "Have We not made for him two eyes?",
    "juz": 30,
    "page": 594,
    "hizb": 60
  },
  {
    "id": 6032,
    "number": 9,
    "key": "90:9",
    "textAr": "وَلِسَانًا وَشَفَتَيْنِ",
    "textEn": "And a tongue and two lips?",
    "juz": 30,
    "page": 594,
    "hizb": 60
  },
  {
    "id": 6033,
    "number": 10,
    "key": "90:10",
    "textAr": "وَهَدَيْنَـٰهُ ٱلنَّجْدَيْنِ",
    "textEn": "And have shown him the two ways?",
    "juz": 30,
    "page": 594,
    "hizb": 60
  },
  {
    "id": 6034,
    "number": 11,
    "key": "90:11",
    "textAr": "فَلَا ٱقْتَحَمَ ٱلْعَقَبَةَ",
    "textEn": "But he has not broken through the difficult pass.",
    "juz": 30,
    "page": 594,
    "hizb": 60
  },
  {
    "id": 6035,
    "number": 12,
    "key": "90:12",
    "textAr": "وَمَآ أَدْرَىٰكَ مَا ٱلْعَقَبَةُ",
    "textEn": "And what can make you know what is [breaking through] the difficult pass?",
    "juz": 30,
    "page": 594,
    "hizb": 60
  },
  {
    "id": 6036,
    "number": 13,
    "key": "90:13",
    "textAr": "فَكُّ رَقَبَةٍ",
    "textEn": "It is the freeing of a slave",
    "juz": 30,
    "page": 594,
    "hizb": 60
  },
  {
    "id": 6037,
    "number": 14,
    "key": "90:14",
    "textAr": "أَوْ إِطْعَـٰمٌ فِى يَوْمٍ ذِى مَسْغَبَةٍ",
    "textEn": "Or feeding on a day of severe hunger",
    "juz": 30,
    "page": 594,
    "hizb": 60
  },
  {
    "id": 6038,
    "number": 15,
    "key": "90:15",
    "textAr": "يَتِيمًا ذَا مَقْرَبَةٍ",
    "textEn": "An orphan of near relationship",
    "juz": 30,
    "page": 594,
    "hizb": 60
  },
  {
    "id": 6039,
    "number": 16,
    "key": "90:16",
    "textAr": "أَوْ مِسْكِينًا ذَا مَتْرَبَةٍ",
    "textEn": "Or a needy person in misery",
    "juz": 30,
    "page": 594,
    "hizb": 60
  },
  {
    "id": 6040,
    "number": 17,
    "key": "90:17",
    "textAr": "ثُمَّ كَانَ مِنَ ٱلَّذِينَ ءَامَنُوا۟ وَتَوَاصَوْا۟ بِٱلصَّبْرِ وَتَوَاصَوْا۟ بِٱلْمَرْحَمَةِ",
    "textEn": "And then being among those who believed and advised one another to patience and advised one another to compassion.",
    "juz": 30,
    "page": 594,
    "hizb": 60
  },
  {
    "id": 6041,
    "number": 18,
    "key": "90:18",
    "textAr": "أُو۟لَـٰٓئِكَ أَصْحَـٰبُ ٱلْمَيْمَنَةِ",
    "textEn": "Those are the companions of the right.",
    "juz": 30,
    "page": 594,
    "hizb": 60
  },
  {
    "id": 6042,
    "number": 19,
    "key": "90:19",
    "textAr": "وَٱلَّذِينَ كَفَرُوا۟ بِـَٔايَـٰتِنَا هُمْ أَصْحَـٰبُ ٱلْمَشْـَٔمَةِ",
    "textEn": "But they who disbelieved in Our signs - those are the companions of the left.",
    "juz": 30,
    "page": 594,
    "hizb": 60
  },
  {
    "id": 6043,
    "number": 20,
    "key": "90:20",
    "textAr": "عَلَيْهِمْ نَارٌ مُّؤْصَدَةٌۢ",
    "textEn": "Over them will be fire closed in.",
    "juz": 30,
    "page": 594,
    "hizb": 60
  }
]