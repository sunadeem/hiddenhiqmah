[
  {
    "id": 6107,
    "number": 1,
    "key": "96:1",
    "textAr": "ٱقْرَأْ بِٱسْمِ رَبِّكَ ٱلَّذِى خَلَقَ",
    "textEn": "Recite in the name of your Lord who created",
    "juz": 30,
    "page": 597,
    "hizb": 60
  },
  {
    "id": 6108,
    "number": 2,
    "key": "96:2",
    "textAr": "خَلَقَ ٱلْإِنسَـٰنَ مِنْ عَلَقٍ",
    "textEn": "Created man from a clinging substance.",
    "juz": 30,
    "page": 597,
    "hizb": 60
  },
  {
    "id": 6109,
    "number": 3,
    "key": "96:3",
    "textAr": "ٱقْرَأْ وَرَبُّكَ ٱلْأَكْرَمُ",
    "textEn": "Recite, and your Lord is the most Generous -",
    "juz": 30,
    "page": 597,
    "hizb": 60
  },
  {
    "id": 6110,
    "number": 4,
    "key": "96:4",
    "textAr": "ٱلَّذِى عَلَّمَ بِٱلْقَلَمِ",
    "textEn": "Who taught by the pen",
    "juz": 30,
    "page": 597,
    "hizb": 60
  },
  {
    "id": 6111,
    "number": 5,
    "key": "96:5",
    "textAr": "عَلَّمَ ٱلْإِنسَـٰنَ مَا لَمْ يَعْلَمْ",
    "textEn": "Taught man that which he knew not.",
    "juz": 30,
    "page": 597,
    "hizb": 60
  },
  {
    "id": 6112,
    "number": 6,
    "key": "96:6",
    "textAr": "كَلَّآ إِنَّ ٱلْإِنسَـٰنَ لَيَطْغَىٰٓ",
    "textEn": "No! [But] indeed, man transgresses",
    "juz": 30,
    "page": 597,
    "hizb": 60
  },
  {
    "id": 6113,
    "number": 7,
    "key": "96:7",
    "textAr": "أَن رَّءَاهُ ٱسْتَغْنَىٰٓ",
    "textEn": "Because he sees himself self-sufficient.",
    "juz": 30,
    "page": 597,
    "hizb": 60
  },
  {
    "id": 6114,
    "number": 8,
    "key": "96:8",
    "textAr": "إِنَّ إِلَىٰ رَبِّكَ ٱلرُّجْعَىٰٓ",
    "textEn": "Indeed, to your Lord is the return.",
    "juz": 30,
    "page": 597,
    "hizb": 60
  },
  {
    "id": 6115,
    "number": 9,
    "key": "96:9",
    "textAr": "أَرَءَيْتَ ٱلَّذِى يَنْهَىٰ",
    "textEn": "Have you seen the one who forbids",
    "juz": 30,
    "page": 597,
    "hizb": 60
  },
  {
    "id": 6116,
    "number": 10,
    "key": "96:10",
    "textAr": "عَبْدًا إِذَا صَلَّىٰٓ",
    "textEn": "A servant when he prays?",
    "juz": 30,
    "page": 597,
    "hizb": 60
  },
  {
    "id": 6117,
    "number": 11,
    "key": "96:11",
    "textAr": "أَرَءَيْتَ إِن كَانَ عَلَى ٱلْهُدَىٰٓ",
    "textEn": "Have you seen if he is upon guidance",
    "juz": 30,
    "page": 597,
    "hizb": 60
  },
  {
    "id": 6118,
    "number": 12,
    "key": "96:12",
    "textAr": "أَوْ أَمَرَ بِٱلتَّقْوَىٰٓ",
    "textEn": "Or enjoins righteousness?",
    "juz": 30,
    "page": 597,
    "hizb": 60
  },
  {
    "id": 6119,
    "number": 13,
    "key": "96:13",
    "textAr": "أَرَءَيْتَ إِن كَذَّبَ وَتَوَلَّىٰٓ",
    "textEn": "Have you seen if he denies and turns away -",
    "juz": 30,
    "page": 597,
    "hizb": 60
  },
  {
    "id": 6120,
    "number": 14,
    "key": "96:14",
    "textAr": "أَلَمْ يَعْلَم بِأَنَّ ٱللَّهَ يَرَىٰ",
    "textEn": "Does he not know that Allāh sees?",
    "juz": 30,
    "page": 597,
    "hizb": 60
  },
  {
    "id": 6121,
    "number": 15,
    "key": "96:15",
    "textAr": "كَلَّا لَئِن لَّمْ يَنتَهِ لَنَسْفَعًۢا بِٱلنَّاصِيَةِ",
    "textEn": "No! If he does not desist, We will surely drag him by the forelock",
    "juz": 30,
    "page": 597,
    "hizb": 60
  },
  {
    "id": 6122,
    "number": 16,
    "key": "96:16",
    "textAr": "نَاصِيَةٍ كَـٰذِبَةٍ خَاطِئَةٍ",
    "textEn": "A lying, sinning forelock.",
    "juz": 30,
    "page": 597,
    "hizb": 60
  },
  {
    "id": 6123,
    "number": 17,
    "key": "96:17",
    "textAr": "فَلْيَدْعُ نَادِيَهُۥ",
    "textEn": "Then let him call his associates;",
    "juz": 30,
    "page": 597,
    "hizb": 60
  },
  {
    "id": 6124,
    "number": 18,
    "key": "96:18",
    "textAr": "سَنَدْعُ ٱلزَّبَانِيَةَ",
    "textEn": "We will call the angels of Hell.",
    "juz": 30,
    "page": 597,
    "hizb": 60
  },
  {
    "id": 6125,
    "number": 19,
    "key": "96:19",
    "textAr": "كَلَّا لَا تُطِعْهُ وَٱسْجُدْ وَٱقْتَرِب ۩",
    "textEn": "No! Do not obey him. But prostrate and draw near [to Allāh].",
    "juz": 30,
    "page": 597,
    "hizb": 60
  }
]