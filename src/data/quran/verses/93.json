[
  {
    "id": 6080,
    "number": 1,
    "key": "93:1",
    "textAr": "وَٱلضُّحَىٰ",
    "textEn": "By the morning brightness",
    "juz": 30,
    "page": 596,
    "hizb": 60
  },
  {
    "id": 6081,
    "number": 2,
    "key": "93:2",
    "textAr": "وَٱلَّيْلِ إِذَا سَجَىٰ",
    "textEn": "And [by] the night when it covers with darkness,",
    "juz": 30,
    "page": 596,
    "hizb": 60
  },
  {
    "id": 6082,
    "number": 3,
    "key": "93:3",
    "textAr": "مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَىٰ",
    "textEn": "Your Lord has not taken leave of you, [O Muḥammad], nor has He detested [you].",
    "juz": 30,
    "page": 596,
    "hizb": 60
  },
  {
    "id": 6083,
    "number": 4,
    "key": "93:4",
    "textAr": "وَلَلْـَٔاخِرَةُ خَيْرٌ لَّكَ مِنَ ٱلْأُولَىٰ",
    "textEn": "And the Hereafter is better for you than the first [life].",
    "juz": 30,
    "page": 596,
    "hizb": 60
  },
  {
    "id": 6084,
    "number": 5,
    "key": "93:5",
    "textAr": "وَلَسَوْفَ يُعْطِيكَ رَبُّكَ فَتَرْضَىٰٓ",
    "textEn": "And your Lord is going to give you, and you will be satisfied.",
    "juz": 30,
    "page": 596,
    "hizb": 60
  },
  {
    "id": 6085,
    "number": 6,
    "key": "93:6",
    "textAr": "أَلَمْ يَجِدْكَ يَتِيمًا فَـَٔاوَىٰ",
    "textEn": "Did He not find you an orphan and give [you] refuge?",
    "juz": 30,
    "page": 596,
    "hizb": 60
  },
  {
    "id": 6086,
    "number": 7,
    "key": "93:7",
    "textAr": "وَوَجَدَكَ ضَآلًّا فَهَدَىٰ",
    "textEn": "And He found you lost and guided [you],",
    "juz": 30,
    "page": 596,
    "hizb": 60
  },
  {
    "id": 6087,
    "number": 8,
    "key": "93:8",
    "textAr": "وَوَجَدَكَ عَآئِلًا فَأَغْنَىٰ",
    "textEn": "And He found you poor and made [you] self-sufficient.",
    "juz": 30,
    "page": 596,
    "hizb": 60
  },
  {
    "id": 6088,
    "number": 9,
    "key": "93:9",
    "textAr": "فَأَمَّا ٱلْيَتِيمَ فَلَا تَقْهَرْ",
    "textEn": "So as for the orphan, do not oppress [him].",
    "juz": 30,
    "page": 596,
    "hizb": 60
  },
  {
    "id": 6089,
    "number": 10,
    "key": "93:10",
    "textAr": "وَأَمَّا ٱلسَّآئِلَ فَلَا تَنْهَرْ",
    "textEn": "And as for the petitioner, do not repel [him].",
    "juz": 30,
    "page": 596,
    "hizb": 60
  },
  {
    "id": 6090,
    "number": 11,
    "key": "93:11",
    "textAr": "وَأَمَّا بِنِعْمَةِ رَبِّكَ فَحَدِّثْ",
    "textEn": "But as for the favor of your Lord, report [it].",
    "juz": 30,
    "page": 596,
    "hizb": 60
  }
]