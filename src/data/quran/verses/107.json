[
  {
    "id": 6198,
    "number": 1,
    "key": "107:1",
    "textAr": "أَرَءَيْتَ ٱلَّذِى يُكَذِّبُ بِٱلدِّينِ",
    "textEn": "Have you seen the one who denies the Recompense?",
    "juz": 30,
    "page": 602,
    "hizb": 60
  },
  {
    "id": 6199,
    "number": 2,
    "key": "107:2",
    "textAr": "فَذَٰلِكَ ٱلَّذِى يَدُعُّ ٱلْيَتِيمَ",
    "textEn": "For that is the one who drives away the orphan",
    "juz": 30,
    "page": 602,
    "hizb": 60
  },
  {
    "id": 6200,
    "number": 3,
    "key": "107:3",
    "textAr": "وَلَا يَحُضُّ عَلَىٰ طَعَامِ ٱلْمِسْكِينِ",
    "textEn": "And does not encourage the feeding of the poor.",
    "juz": 30,
    "page": 602,
    "hizb": 60
  },
  {
    "id": 6201,
    "number": 4,
    "key": "107:4",
    "textAr": "فَوَيْلٌ لِّلْمُصَلِّينَ",
    "textEn": "So woe to those who pray",
    "juz": 30,
    "page": 602,
    "hizb": 60
  },
  {
    "id": 6202,
    "number": 5,
    "key": "107:5",
    "textAr": "ٱلَّذِينَ هُمْ عَن صَلَاتِهِمْ سَاهُونَ",
    "textEn": "[But] who are heedless of their prayer -",
    "juz": 30,
    "page": 602,
    "hizb": 60
  },
  {
    "id": 6203,
    "number": 6,
    "key": "107:6",
    "textAr": "ٱلَّذِينَ هُمْ يُرَآءُونَ",
    "textEn": "Those who make show [of their deeds]",
    "juz": 30,
    "page": 602,
    "hizb": 60
  },
  {
    "id": 6204,
    "number": 7,
    "key": "107:7",
    "textAr": "وَيَمْنَعُونَ ٱلْمَاعُونَ",
    "textEn": "And withhold [simple] assistance.",
    "juz": 30,
    "page": 602,
    "hizb": 60
  }
]