[{"id": 6226, "number": 1, "key": "113:1", "textAr": "قُلْ أَعُوذُ بِرَبِّ ٱلْفَلَقِ", "textEn": "Say, \"I seek refuge in the Lord of daybreak", "juz": 30, "page": 604, "hizb": 60, "textTranslit": "Qul a'uzoo bi rabbil-falaq"}, {"id": 6227, "number": 2, "key": "113:2", "textAr": "مِن شَرِّ مَا خَلَقَ", "textEn": "From the evil of that which He created", "juz": 30, "page": 604, "hizb": 60, "textTranslit": "Min sharri ma khalaq"}, {"id": 6228, "number": 3, "key": "113:3", "textAr": "وَمِن شَرِّ غَاسِقٍ إِذَا وَقَبَ", "textEn": "And from the evil of darkness when it settles", "juz": 30, "page": 604, "hizb": 60, "textTranslit": "Wa min sharri ghasiqin iza waqab"}, {"id": 6229, "number": 4, "key": "113:4", "textAr": "وَمِن شَرِّ ٱلنَّفَّـٰثَـٰتِ فِى ٱلْعُقَدِ", "textEn": "And from the evil of the blowers in knots", "juz": 30, "page": 604, "hizb": 60, "textTranslit": "Wa min sharrin-naffaa-thaati fil 'uqad"}, {"id": 6230, "number": 5, "key": "113:5", "textAr": "وَمِن شَرِّ حَاسِدٍ إِذَا حَسَدَ", "textEn": "And from the evil of an envier when he envies.\"", "juz": 30, "page": 604, "hizb": 60, "textTranslit": "Wa min shar ri haasidin iza hasad"}]