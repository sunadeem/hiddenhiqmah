[{"id": 5932, "number": 1, "key": "86:1", "textAr": "وَٱلسَّمَآءِ وَٱلطَّارِقِ", "textEn": "By the sky and the night comer", "juz": 30, "page": 591, "hizb": 59, "textTranslit": "Wassamaaa'i wattaariq"}, {"id": 5933, "number": 2, "key": "86:2", "textAr": "وَمَآ أَدْرَىٰكَ مَا ٱلطَّارِقُ", "textEn": "And what can make you know what is the night comer?", "juz": 30, "page": 591, "hizb": 59, "textTranslit": "Wa maaa adraaka mattaariq"}, {"id": 5934, "number": 3, "key": "86:3", "textAr": "ٱلنَّجْمُ ٱلثَّاقِبُ", "textEn": "It is the piercing star", "juz": 30, "page": 591, "hizb": 59, "textTranslit": "Annajmus saaqib"}, {"id": 5935, "number": 4, "key": "86:4", "textAr": "إِن كُلُّ نَفْسٍ لَّمَّا عَلَيْهَا حَافِظٌ", "textEn": "There is no soul but that it has over it a protector.", "juz": 30, "page": 591, "hizb": 59, "textTranslit": "In kullu nafsil lammaa 'alaihaa haafiz"}, {"id": 5936, "number": 5, "key": "86:5", "textAr": "فَلْيَنظُرِ ٱلْإِنسَـٰنُ مِمَّ خُلِقَ", "textEn": "So let man observe from what he was created.", "juz": 30, "page": 591, "hizb": 59, "textTranslit": "Fal yanzuril insaanu mimma khuliq"}, {"id": 5937, "number": 6, "key": "86:6", "textAr": "خُلِقَ مِن مَّآءٍ دَافِقٍ", "textEn": "He was created from a fluid, ejected,", "juz": 30, "page": 591, "hizb": 59, "textTranslit": "Khuliqa mim maaa'in daafiq"}, {"id": 5938, "number": 7, "key": "86:7", "textAr": "يَخْرُجُ مِنۢ بَيْنِ ٱلصُّلْبِ وَٱلتَّرَآئِبِ", "textEn": "Emerging from between the backbone and the ribs.", "juz": 30, "page": 591, "hizb": 59, "textTranslit": "Yakhruju mim bainissulbi wat taraaa'ib"}, {"id": 5939, "number": 8, "key": "86:8", "textAr": "إِنَّهُۥ عَلَىٰ رَجْعِهِۦ لَقَادِرٌ", "textEn": "Indeed, He [i.e., Allāh], to return him [to life], is Able.", "juz": 30, "page": 591, "hizb": 59, "textTranslit": "Innahoo 'alaa raj'ihee laqaadir"}, {"id": 5940, "number": 9, "key": "86:9", "textAr": "يَوْمَ تُبْلَى ٱلسَّرَآئِرُ", "textEn": "The Day when secrets will be put on trial,", "juz": 30, "page": 591, "hizb": 59, "textTranslit": "Yawma tublas saraaa'ir"}, {"id": 5941, "number": 10, "key": "86:10", "textAr": "فَمَا لَهُۥ مِن قُوَّةٍ وَلَا نَاصِرٍ", "textEn": "Then he [i.e., man] will have no power or any helper.", "juz": 30, "page": 591, "hizb": 59, "textTranslit": "Famaa lahoo min quwwatinw wa laa naasir"}, {"id": 5942, "number": 11, "key": "86:11", "textAr": "وَٱلسَّمَآءِ ذَاتِ ٱلرَّجْعِ", "textEn": "By the sky which sends back", "juz": 30, "page": 591, "hizb": 59, "textTranslit": "Wassamaaa'i zaatir raj'"}, {"id": 5943, "number": 12, "key": "86:12", "textAr": "وَٱلْأَرْضِ ذَاتِ ٱلصَّدْعِ", "textEn": "And [by] the earth which splits,", "juz": 30, "page": 591, "hizb": 59, "textTranslit": "Wal ardi zaatis sad'"}, {"id": 5944, "number": 13, "key": "86:13", "textAr": "إِنَّهُۥ لَقَوْلٌ فَصْلٌ", "textEn": "Indeed, it [i.e., the Qur’ān] is a decisive statement,", "juz": 30, "page": 591, "hizb": 59, "textTranslit": "Innahoo laqawlun fasl"}, {"id": 5945, "number": 14, "key": "86:14", "textAr": "وَمَا هُوَ بِٱلْهَزْلِ", "textEn": "And it is not amusement.", "juz": 30, "page": 591, "hizb": 59, "textTranslit": "Wa maa huwa bil hazl"}, {"id": 5946, "number": 15, "key": "86:15", "textAr": "إِنَّهُمْ يَكِيدُونَ كَيْدًا", "textEn": "Indeed, they are planning a plan,", "juz": 30, "page": 591, "hizb": 59, "textTranslit": "Innahum yakeedoona kaidaa"}, {"id": 5947, "number": 16, "key": "86:16", "textAr": "وَأَكِيدُ كَيْدًا", "textEn": "But I am planning a plan.", "juz": 30, "page": 591, "hizb": 59, "textTranslit": "Wa akeedu kaidaa"}, {"id": 5948, "number": 17, "key": "86:17", "textAr": "فَمَهِّلِ ٱلْكَـٰفِرِينَ أَمْهِلْهُمْ رُوَيْدًۢا", "textEn": "So allow time for the disbelievers. Leave them awhile.", "juz": 30, "page": 591, "hizb": 59, "textTranslit": "Famahhilil kaafireena amhilhum ruwaidaa"}]