[{"id": 5759, "number": 1, "key": "80:1", "textAr": "عَبَسَ وَتَوَلَّىٰٓ", "textEn": "He [i.e., the Prophet (ﷺ) ] frowned and turned away", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "'Abasa wa tawallaa."}, {"id": 5760, "number": 2, "key": "80:2", "textAr": "أَن جَآءَهُ ٱلْأَعْمَىٰ", "textEn": "Because there came to him the blind man, [interrupting].", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "An jaa-ahul 'a-maa"}, {"id": 5761, "number": 3, "key": "80:3", "textAr": "وَمَا يُدْرِيكَ لَعَلَّهُۥ يَزَّكَّىٰٓ", "textEn": "But what would make you perceive, [O Muḥammad], that perhaps he might be purified", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Wa maa yudreeka la'allahu yaz zakkaa."}, {"id": 5762, "number": 4, "key": "80:4", "textAr": "أَوْ يَذَّكَّرُ فَتَنفَعَهُ ٱلذِّكْرَىٰٓ", "textEn": "Or be reminded and the remembrance would benefit him?", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Au yaz zak karu fatanfa 'ahuz zikraa."}, {"id": 5763, "number": 5, "key": "80:5", "textAr": "أَمَّا مَنِ ٱسْتَغْنَىٰ", "textEn": "As for he who thinks himself without need,", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Amma manis taghnaa"}, {"id": 5764, "number": 6, "key": "80:6", "textAr": "فَأَنتَ لَهُۥ تَصَدَّىٰ", "textEn": "To him you give attention.", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Fa-anta lahu tasaddaa"}, {"id": 5765, "number": 7, "key": "80:7", "textAr": "وَمَا عَلَيْكَ أَلَّا يَزَّكَّىٰ", "textEn": "And not upon you [is any blame] if he will not be purified.", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Wa ma 'alaika allaa yaz zakka."}, {"id": 5766, "number": 8, "key": "80:8", "textAr": "وَأَمَّا مَن جَآءَكَ يَسْعَىٰ", "textEn": "But as for he who came to you striving [for knowledge]", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Wa amma man jaa-aka yas'a"}, {"id": 5767, "number": 9, "key": "80:9", "textAr": "وَهُوَ يَخْشَىٰ", "textEn": "While he fears [Allāh],", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Wahuwa yakhshaa,"}, {"id": 5768, "number": 10, "key": "80:10", "textAr": "فَأَنتَ عَنْهُ تَلَهَّىٰ", "textEn": "From him you are distracted.", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Fa-anta 'anhu talah haa."}, {"id": 5769, "number": 11, "key": "80:11", "textAr": "كَلَّآ إِنَّهَا تَذْكِرَةٌ", "textEn": "No! Indeed, they [i.e., these verses] are a reminder;", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Kalla innaha tazkirah"}, {"id": 5770, "number": 12, "key": "80:12", "textAr": "فَمَن شَآءَ ذَكَرَهُۥ", "textEn": "So whoever wills may remember it.", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Faman shaa a zakarah"}, {"id": 5771, "number": 13, "key": "80:13", "textAr": "فِى صُحُفٍ مُّكَرَّمَةٍ", "textEn": "[It is recorded] in honored sheets,", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Fi suhufim mukar rama,"}, {"id": 5772, "number": 14, "key": "80:14", "textAr": "مَّرْفُوعَةٍ مُّطَهَّرَةٍۭ", "textEn": "Exalted and purified,", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Marfoo'atim mutah hara,"}, {"id": 5773, "number": 15, "key": "80:15", "textAr": "بِأَيْدِى سَفَرَةٍ", "textEn": "[Carried] by the hands of messenger-angels,", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Bi'aidee safara"}, {"id": 5774, "number": 16, "key": "80:16", "textAr": "كِرَامٍۭ بَرَرَةٍ", "textEn": "Noble and dutiful.", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Kiraamim bararah."}, {"id": 5775, "number": 17, "key": "80:17", "textAr": "قُتِلَ ٱلْإِنسَـٰنُ مَآ أَكْفَرَهُۥ", "textEn": "Destroyed [i.e., cursed] is man; how disbelieving is he.", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Qutilal-insanu maa akfarah."}, {"id": 5776, "number": 18, "key": "80:18", "textAr": "مِنْ أَىِّ شَىْءٍ خَلَقَهُۥ", "textEn": "From what thing [i.e., substance] did He create him?", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Min aiyyi shai-in Khalaq"}, {"id": 5777, "number": 19, "key": "80:19", "textAr": "مِن نُّطْفَةٍ خَلَقَهُۥ فَقَدَّرَهُۥ", "textEn": "From a sperm-drop He created him and destined for him;", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Min nutfah; khalaqahu faqad-darah."}, {"id": 5778, "number": 20, "key": "80:20", "textAr": "ثُمَّ ٱلسَّبِيلَ يَسَّرَهُۥ", "textEn": "Then He eased the way for him;", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Thummas sabeela yas-sarah"}, {"id": 5779, "number": 21, "key": "80:21", "textAr": "ثُمَّ أَمَاتَهُۥ فَأَقْبَرَهُۥ", "textEn": "Then He causes his death and provides a grave for him.", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Thumma amatahu fa-aqbarah"}, {"id": 5780, "number": 22, "key": "80:22", "textAr": "ثُمَّ إِذَا شَآءَ أَنشَرَهُۥ", "textEn": "Then when He wills, He will resurrect him.", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Thumma iza shaa-a ansharah"}, {"id": 5781, "number": 23, "key": "80:23", "textAr": "كَلَّا لَمَّا يَقْضِ مَآ أَمَرَهُۥ", "textEn": "No! He [i.e., man] has not yet accomplished what He commanded him.", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Kalla lamma yaqdi maa amarah."}, {"id": 5782, "number": 24, "key": "80:24", "textAr": "فَلْيَنظُرِ ٱلْإِنسَـٰنُ إِلَىٰ طَعَامِهِۦٓ", "textEn": "Then let mankind look at his food -", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Falyanzuril insanu ilaa ta-amih"}, {"id": 5783, "number": 25, "key": "80:25", "textAr": "أَنَّا صَبَبْنَا ٱلْمَآءَ صَبًّا", "textEn": "How We poured down water in torrents,", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Anna sabab nalmaa-a sabba."}, {"id": 5784, "number": 26, "key": "80:26", "textAr": "ثُمَّ شَقَقْنَا ٱلْأَرْضَ شَقًّا", "textEn": "Then We broke open the earth, splitting [it with sprouts],", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Thumma sha qaqnal-arda shaqqa."}, {"id": 5785, "number": 27, "key": "80:27", "textAr": "فَأَنۢبَتْنَا فِيهَا حَبًّا", "textEn": "And caused to grow within it grain", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Fa ambatna feeha habba"}, {"id": 5786, "number": 28, "key": "80:28", "textAr": "وَعِنَبًا وَقَضْبًا", "textEn": "And grapes and herbage", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Wa 'inabaw-wa qadba"}, {"id": 5787, "number": 29, "key": "80:29", "textAr": "وَزَيْتُونًا وَنَخْلًا", "textEn": "And olive and palm trees", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Wa zaitoonaw wanakh la'"}, {"id": 5788, "number": 30, "key": "80:30", "textAr": "وَحَدَآئِقَ غُلْبًا", "textEn": "And gardens of dense shrubbery", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Wa hadaa-iqa ghulba"}, {"id": 5789, "number": 31, "key": "80:31", "textAr": "وَفَـٰكِهَةً وَأَبًّا", "textEn": "And fruit and grass -", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Wa faki hataw-wa abba."}, {"id": 5790, "number": 32, "key": "80:32", "textAr": "مَّتَـٰعًا لَّكُمْ وَلِأَنْعَـٰمِكُمْ", "textEn": "[As] enjoyment [i.e., provision] for you and your grazing livestock.", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Mata'al-lakum wa li-an'amikum."}, {"id": 5791, "number": 33, "key": "80:33", "textAr": "فَإِذَا جَآءَتِ ٱلصَّآخَّةُ", "textEn": "But when there comes the Deafening Blast", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Faiza jaa-atis saakhah."}, {"id": 5792, "number": 34, "key": "80:34", "textAr": "يَوْمَ يَفِرُّ ٱلْمَرْءُ مِنْ أَخِيهِ", "textEn": "On the Day a man will flee from his brother", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Yauma yafir-rul mar-u min akheeh"}, {"id": 5793, "number": 35, "key": "80:35", "textAr": "وَأُمِّهِۦ وَأَبِيهِ", "textEn": "And his mother and his father", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Wa ummihee wa abeeh"}, {"id": 5794, "number": 36, "key": "80:36", "textAr": "وَصَـٰحِبَتِهِۦ وَبَنِيهِ", "textEn": "And his wife and his children,", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Wa sahi batihee wa baneeh."}, {"id": 5795, "number": 37, "key": "80:37", "textAr": "لِكُلِّ ٱمْرِئٍ مِّنْهُمْ يَوْمَئِذٍ شَأْنٌ يُغْنِيهِ", "textEn": "For every man, that Day, will be a matter adequate for him.", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Likul limri-im-minuhm yaumaa-izin shaa nuy-yughneeh"}, {"id": 5796, "number": 38, "key": "80:38", "textAr": "وُجُوهٌ يَوْمَئِذٍ مُّسْفِرَةٌ", "textEn": "[Some] faces, that Day, will be bright -", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Wujoo huny-yauma-izim-musfira;"}, {"id": 5797, "number": 39, "key": "80:39", "textAr": "ضَاحِكَةٌ مُّسْتَبْشِرَةٌ", "textEn": "Laughing, rejoicing at good news.", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Dahi katum mustab shirah"}, {"id": 5798, "number": 40, "key": "80:40", "textAr": "وَوُجُوهٌ يَوْمَئِذٍ عَلَيْهَا غَبَرَةٌ", "textEn": "And [other] faces, that Day, will have upon them dust.", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Wa wujoohuy yauma-izin 'alaiha ghabar a"}, {"id": 5799, "number": 41, "key": "80:41", "textAr": "تَرْهَقُهَا قَتَرَةٌ", "textEn": "Blackness will cover them.", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Tarhaquha qatarah."}, {"id": 5800, "number": 42, "key": "80:42", "textAr": "أُو۟لَـٰٓئِكَ هُمُ ٱلْكَفَرَةُ ٱلْفَجَرَةُ", "textEn": "Those are the disbelievers, the wicked ones.", "juz": 30, "page": 585, "hizb": 59, "textTranslit": "Ulaa-ika humul-kafa ratul-fajarah."}]