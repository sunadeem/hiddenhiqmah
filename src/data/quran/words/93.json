{"1": [{"t": "وَٱلضُّحَىٰ", "tr": "wal-ḍuḥā", "m": "By the morning brightness"}], "2": [{"t": "وَٱلَّيْلِ", "tr": "wa-al-layli", "m": "And the night"}, {"t": "إِذَا", "tr": "idhā", "m": "when"}, {"t": "سَجَىٰ", "tr": "sajā", "m": "it covers with darkness"}], "3": [{"t": "مَا", "tr": "mā", "m": "Not"}, {"t": "وَدَّعَكَ", "tr": "waddaʿaka", "m": "has forsaken you"}, {"t": "رَبُّكَ", "tr": "rabbuka", "m": "your Lord"}, {"t": "وَمَا", "tr": "wamā", "m": "and not"}, {"t": "قَلَىٰ", "tr": "qalā", "m": "He is displeased"}], "4": [{"t": "وَلَلْـَٔاخِرَةُ", "tr": "walalākhiratu", "m": "And surely the Hereafter"}, {"t": "خَيْرٌۭ", "tr": "khayrun", "m": "(is) better"}, {"t": "لَّكَ", "tr": "laka", "m": "for you"}, {"t": "مِنَ", "tr": "mina", "m": "than"}, {"t": "ٱلْأُولَىٰ", "tr": "l-ūlā", "m": "the first"}], "5": [{"t": "وَلَسَوْفَ", "tr": "walasawfa", "m": "And soon"}, {"t": "يُعْطِيكَ", "tr": "yuʿ'ṭīka", "m": "will give you"}, {"t": "رَبُّكَ", "tr": "rabbuka", "m": "your Lord"}, {"t": "فَتَرْضَىٰٓ", "tr": "fatarḍā", "m": "then you will be satisfied"}], "6": [{"t": "أَلَمْ", "tr": "alam", "m": "Did not"}, {"t": "يَجِدْكَ", "tr": "yajid'ka", "m": "He find you"}, {"t": "يَتِيمًۭا", "tr": "yatīman", "m": "an orphan"}, {"t": "فَـَٔاوَىٰ", "tr": "faāwā", "m": "and give shelter"}], "7": [{"t": "وَوَجَدَكَ", "tr": "wawajadaka", "m": "And He found you"}, {"t": "ضَآلًّۭا", "tr": "ḍāllan", "m": "lost"}, {"t": "فَهَدَىٰ", "tr": "fahadā", "m": "so He guided"}], "8": [{"t": "وَوَجَدَكَ", "tr": "wawajadaka", "m": "And He found you"}, {"t": "عَآئِلًۭا", "tr": "ʿāilan", "m": "in need"}, {"t": "فَأَغْنَىٰ", "tr": "fa-aghnā", "m": "so He made self-sufficient"}], "9": [{"t": "فَأَمَّا", "tr": "fa-ammā", "m": "So as for"}, {"t": "ٱلْيَتِيمَ", "tr": "l-yatīma", "m": "the orphan"}, {"t": "فَلَا", "tr": "falā", "m": "then (do) not"}, {"t": "تَقْهَرْ", "tr": "taqhar", "m": "oppress"}], "10": [{"t": "وَأَمَّا", "tr": "wa-ammā", "m": "And as for"}, {"t": "ٱلسَّآئِلَ", "tr": "l-sāila", "m": "one who asks"}, {"t": "فَلَا", "tr": "falā", "m": "then (do) not"}, {"t": "تَنْهَرْ", "tr": "tanhar", "m": "repel"}], "11": [{"t": "وَأَمَّا", "tr": "wa-ammā", "m": "But as for"}, {"t": "بِنِعْمَةِ", "tr": "biniʿ'mati", "m": "(the) Favor"}, {"t": "رَبِّكَ", "tr": "rabbika", "m": "(of) your Lord"}, {"t": "فَحَدِّثْ", "tr": "faḥaddith", "m": "narrate"}]}