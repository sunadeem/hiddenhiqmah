{"1": [{"t": "إِذَا", "tr": "idhā", "m": "When"}, {"t": "جَآءَ", "tr": "jāa", "m": "comes"}, {"t": "نَصْرُ", "tr": "naṣru", "m": "(the) Help"}, {"t": "ٱللَّهِ", "tr": "l-lahi", "m": "(of) Allah"}, {"t": "وَٱلْفَتْحُ", "tr": "wal-fatḥu", "m": "and the Victory"}], "2": [{"t": "وَرَأَيْتَ", "tr": "wara-ayta", "m": "And you see"}, {"t": "ٱلنَّاسَ", "tr": "l-nāsa", "m": "the people"}, {"t": "يَدْخُلُونَ", "tr": "yadkhulūna", "m": "entering"}, {"t": "فِى", "tr": "fī", "m": "into"}, {"t": "دِينِ", "tr": "dīni", "m": "(the) religion"}, {"t": "ٱللَّهِ", "tr": "l-lahi", "m": "(of) Allah"}, {"t": "أَفْوَاجًۭا", "tr": "afwājan", "m": "(in) multitudes"}], "3": [{"t": "فَسَبِّحْ", "tr": "fasabbiḥ", "m": "Then glorify"}, {"t": "بِحَمْدِ", "tr": "biḥamdi", "m": "with (the) praises"}, {"t": "رَبِّكَ", "tr": "rabbika", "m": "(of) your Lord"}, {"t": "وَٱسْتَغْفِرْهُ ۚ", "tr": "wa-is'taghfir'hu", "m": "and ask His forgiveness"}, {"t": "إِنَّهُۥ", "tr": "innahu", "m": "Indeed, He"}, {"t": "كَانَ", "tr": "kāna", "m": "is"}, {"t": "تَوَّابًۢا", "tr": "tawwāban", "m": "Oft-Returning"}]}