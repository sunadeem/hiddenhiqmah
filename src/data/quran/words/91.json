{"1": [{"t": "وَٱلشَّمْسِ", "tr": "wal-shamsi", "m": "By the sun"}, {"t": "وَضُحَىٰهَا", "tr": "waḍuḥāhā", "m": "and its brightness"}], "2": [{"t": "وَٱلْقَمَرِ", "tr": "wal-qamari", "m": "And the moon"}, {"t": "إِذَا", "tr": "idhā", "m": "when"}, {"t": "تَلَىٰهَا", "tr": "talāhā", "m": "it follows it"}], "3": [{"t": "وَٱلنَّهَارِ", "tr": "wal-nahāri", "m": "And the day"}, {"t": "إِذَا", "tr": "idhā", "m": "when"}, {"t": "جَلَّىٰهَا", "tr": "jallāhā", "m": "it displays it"}], "4": [{"t": "وَٱلَّيْلِ", "tr": "wa-al-layli", "m": "And the night"}, {"t": "إِذَا", "tr": "idhā", "m": "when"}, {"t": "يَغْشَىٰهَا", "tr": "yaghshāhā", "m": "it covers it"}], "5": [{"t": "وَٱلسَّمَآءِ", "tr": "wal-samāi", "m": "And the heaven"}, {"t": "وَمَا", "tr": "wamā", "m": "and (He) Who"}, {"t": "بَنَىٰهَا", "tr": "banāhā", "m": "constructed it"}], "6": [{"t": "وَٱلْأَرْضِ", "tr": "wal-arḍi", "m": "And the earth"}, {"t": "وَمَا", "tr": "wamā", "m": "and by (He) Who"}, {"t": "طَحَىٰهَا", "tr": "ṭaḥāhā", "m": "spread it"}], "7": [{"t": "وَنَفْسٍۢ", "tr": "wanafsin", "m": "And (the) soul"}, {"t": "وَمَا", "tr": "wamā", "m": "and (He) Who"}, {"t": "سَوَّىٰهَا", "tr": "sawwāhā", "m": "proportioned it"}], "8": [{"t": "فَأَلْهَمَهَا", "tr": "fa-alhamahā", "m": "And He inspired it"}, {"t": "فُجُورَهَا", "tr": "fujūrahā", "m": "(to distinguish) its wickedness"}, {"t": "وَتَقْوَىٰهَا", "tr": "wataqwāhā", "m": "and its righteousness"}], "9": [{"t": "قَدْ", "tr": "qad", "m": "Indeed"}, {"t": "أَفْلَحَ", "tr": "aflaḥa", "m": "he succeeds"}, {"t": "مَن", "tr": "man", "m": "who"}, {"t": "زَكَّىٰهَا", "tr": "zakkāhā", "m": "purifies it"}], "10": [{"t": "وَقَدْ", "tr": "waqad", "m": "And indeed"}, {"t": "خَابَ", "tr": "khāba", "m": "he fails"}, {"t": "مَن", "tr": "man", "m": "who"}, {"t": "دَسَّىٰهَا", "tr": "dassāhā", "m": "buries it"}], "11": [{"t": "كَذَّبَتْ", "tr": "kadhabat", "m": "Denied"}, {"t": "ثَمُودُ", "tr": "thamūdu", "m": "Thamud"}, {"t": "بِطَغْوَىٰهَآ", "tr": "biṭaghwāhā", "m": "by their transgression"}], "12": [{"t": "إِذِ", "tr": "idhi", "m": "When"}, {"t": "ٱنۢبَعَثَ", "tr": "inbaʿatha", "m": "(was) sent forth"}, {"t": "أَشْقَىٰهَا", "tr": "ashqāhā", "m": "(the) most wicked of them"}], "13": [{"t": "فَقَالَ", "tr": "faqāla", "m": "But said"}, {"t": "لَهُمْ", "tr": "lahum", "m": "to them"}, {"t": "رَسُولُ", "tr": "rasūlu", "m": "(the) Messenger"}, {"t": "ٱللَّهِ", "tr": "l-lahi", "m": "(of) Allah"}, {"t": "نَاقَةَ", "tr": "nāqata", "m": "(It is the) she-camel"}, {"t": "ٱللَّهِ", "tr": "l-lahi", "m": "(of) Allah"}, {"t": "وَسُقْيَـٰهَا", "tr": "wasuq'yāhā", "m": "and her drink"}], "14": [{"t": "فَكَذَّبُوهُ", "tr": "fakadhabūhu", "m": "But they denied him"}, {"t": "فَعَقَرُوهَا", "tr": "faʿaqarūhā", "m": "and they hamstrung her"}, {"t": "فَدَمْدَمَ", "tr": "fadamdama", "m": "So destroyed"}, {"t": "عَلَيْهِمْ", "tr": "ʿalayhim", "m": "them"}, {"t": "رَبُّهُم", "tr": "rabbuhum", "m": "their Lord"}, {"t": "بِذَنۢبِهِمْ", "tr": "bidhanbihim", "m": "for their sin"}, {"t": "فَسَوَّىٰهَا", "tr": "fasawwāhā", "m": "and leveled them"}], "15": [{"t": "وَلَا", "tr": "walā", "m": "And not"}, {"t": "يَخَافُ", "tr": "yakhāfu", "m": "He fears"}, {"t": "عُقْبَـٰهَا", "tr": "ʿuq'bāhā", "m": "its consequences"}]}