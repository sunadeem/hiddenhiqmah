{"1": [{"t": "بِسْمِ", "tr": "bis'mi", "m": "In (the) name"}, {"t": "ٱللَّهِ", "tr": "l-lahi", "m": "(of) Allah"}, {"t": "ٱلرَّحْمَـٰنِ", "tr": "l-raḥmāni", "m": "the Most Gracious"}, {"t": "ٱلرَّحِيمِ", "tr": "l-raḥīmi", "m": "the Most Merciful"}], "2": [{"t": "ٱلْحَمْدُ", "tr": "al-ḥamdu", "m": "All praises and thanks"}, {"t": "لِلَّهِ", "tr": "lillahi", "m": "(be) to Allah"}, {"t": "رَبِّ", "tr": "rabbi", "m": "the Lord"}, {"t": "ٱلْعَـٰلَمِينَ", "tr": "l-ʿālamīna", "m": "of the universe"}], "3": [{"t": "ٱلرَّحْمَـٰنِ", "tr": "al-raḥmāni", "m": "The Most Gracious"}, {"t": "ٱلرَّحِيمِ", "tr": "l-raḥīmi", "m": "the Most Merciful"}], "4": [{"t": "مَـٰلِكِ", "tr": "māliki", "m": "(The) Master"}, {"t": "يَوْمِ", "tr": "yawmi", "m": "(of the) Day"}, {"t": "ٱلدِّينِ", "tr": "l-dīni", "m": "(of the) Judgment"}], "5": [{"t": "إِيَّاكَ", "tr": "iyyāka", "m": "You Alone"}, {"t": "نَعْبُدُ", "tr": "naʿbudu", "m": "we worship"}, {"t": "وَإِيَّاكَ", "tr": "wa-iyyāka", "m": "and You Alone"}, {"t": "نَسْتَعِينُ", "tr": "nastaʿīnu", "m": "we ask for help"}], "6": [{"t": "ٱهْدِنَا", "tr": "ih'dinā", "m": "Guide us"}, {"t": "ٱلصِّرَٰطَ", "tr": "l-ṣirāṭa", "m": "(to) the path"}, {"t": "ٱلْمُسْتَقِيمَ", "tr": "l-mus'taqīma", "m": "the straight"}], "7": [{"t": "صِرَٰطَ", "tr": "ṣirāṭa", "m": "(The) path"}, {"t": "ٱلَّذِينَ", "tr": "alladhīna", "m": "(of) those"}, {"t": "أَنْعَمْتَ", "tr": "anʿamta", "m": "You have bestowed (Your) Favors"}, {"t": "عَلَيْهِمْ", "tr": "ʿalayhim", "m": "on them"}, {"t": "غَيْرِ", "tr": "ghayri", "m": "not (of)"}, {"t": "ٱلْمَغْضُوبِ", "tr": "l-maghḍūbi", "m": "those who earned (Your) wrath"}, {"t": "عَلَيْهِمْ", "tr": "ʿalayhim", "m": "on themselves"}, {"t": "وَلَا", "tr": "walā", "m": "and not"}, {"t": "ٱلضَّآلِّينَ", "tr": "l-ḍālīna", "m": "(of) those who go astray"}]}