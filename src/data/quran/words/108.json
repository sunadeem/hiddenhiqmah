{"1": [{"t": "إِنَّآ", "tr": "innā", "m": "Indeed, We"}, {"t": "أَعْطَيْنَـٰكَ", "tr": "aʿṭaynāka", "m": "We have given you"}, {"t": "ٱلْكَوْثَرَ", "tr": "l-kawthara", "m": "Al-Kauthar"}], "2": [{"t": "فَصَلِّ", "tr": "faṣalli", "m": "So pray"}, {"t": "لِرَبِّكَ", "tr": "lirabbika", "m": "to your Lord"}, {"t": "وَٱنْحَرْ", "tr": "wa-in'ḥar", "m": "and sacrifice"}], "3": [{"t": "إِنَّ", "tr": "inna", "m": "Indeed"}, {"t": "شَانِئَكَ", "tr": "shāni-aka", "m": "your enemy "}, {"t": "هُوَ", "tr": "huwa", "m": "he (is)"}, {"t": "ٱلْأَبْتَرُ", "tr": "l-abtaru", "m": "the one cut off"}]}