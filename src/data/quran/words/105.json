{"1": [{"t": "أَلَمْ", "tr": "alam", "m": "Have not"}, {"t": "تَرَ", "tr": "tara", "m": "you seen"}, {"t": "كَيْفَ", "tr": "kayfa", "m": "how"}, {"t": "فَعَلَ", "tr": "faʿala", "m": "dealt"}, {"t": "رَبُّكَ", "tr": "rabbuka", "m": "your Lord"}, {"t": "بِأَصْحَـٰبِ", "tr": "bi-aṣḥābi", "m": "with (the) Companions"}, {"t": "ٱلْفِيلِ", "tr": "l-fīli", "m": "(of the) Elephant"}], "2": [{"t": "أَلَمْ", "tr": "alam", "m": "Did not"}, {"t": "يَجْعَلْ", "tr": "yajʿal", "m": "He make"}, {"t": "كَيْدَهُمْ", "tr": "kaydahum", "m": "their plan"}, {"t": "فِى", "tr": "fī", "m": "go"}, {"t": "تَضْلِيلٍۢ", "tr": "taḍlīlin", "m": "astray"}], "3": [{"t": "وَأَرْسَلَ", "tr": "wa-arsala", "m": "And He sent"}, {"t": "عَلَيْهِمْ", "tr": "ʿalayhim", "m": "against them"}, {"t": "طَيْرًا", "tr": "ṭayran", "m": "birds"}, {"t": "أَبَابِيلَ", "tr": "abābīla", "m": "(in) flocks"}], "4": [{"t": "تَرْمِيهِم", "tr": "tarmīhim", "m": "Striking them"}, {"t": "بِحِجَارَةٍۢ", "tr": "biḥijāratin", "m": "with stones"}, {"t": "مِّن", "tr": "min", "m": "of"}, {"t": "سِجِّيلٍۢ", "tr": "sijjīlin", "m": "baked clay"}], "5": [{"t": "فَجَعَلَهُمْ", "tr": "fajaʿalahum", "m": "Then He made them"}, {"t": "كَعَصْفٍۢ", "tr": "kaʿaṣfin", "m": "like straw"}, {"t": "مَّأْكُولٍۭ", "tr": "makūlin", "m": "eaten up"}]}