# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (any depth — monorepo-friendly)
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/

# next.js (any depth)
.next/
out/

# production
build/

# turborepo
.turbo/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code local state
.claude/

# Editor
.vscode/
.idea/
