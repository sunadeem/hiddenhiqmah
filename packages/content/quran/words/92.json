{"1": [{"t": "وَٱلَّيْلِ", "tr": "wa-al-layli", "m": "By the night"}, {"t": "إِذَا", "tr": "idhā", "m": "when"}, {"t": "يَغْشَىٰ", "tr": "yaghshā", "m": "it covers"}], "2": [{"t": "وَٱلنَّهَارِ", "tr": "wal-nahāri", "m": "And the day"}, {"t": "إِذَا", "tr": "idhā", "m": "when"}, {"t": "تَجَلَّىٰ", "tr": "tajallā", "m": "it shines in brightness"}], "3": [{"t": "وَمَا", "tr": "wamā", "m": "And He Who"}, {"t": "خَلَقَ", "tr": "khalaqa", "m": "created"}, {"t": "ٱلذَّكَرَ", "tr": "l-dhakara", "m": "the male"}, {"t": "وَٱلْأُنثَىٰٓ", "tr": "wal-unthā", "m": "and the female"}], "4": [{"t": "إِنَّ", "tr": "inna", "m": "Indeed"}, {"t": "سَعْيَكُمْ", "tr": "saʿyakum", "m": "your efforts"}, {"t": "لَشَتَّىٰ", "tr": "lashattā", "m": "(are) surely diverse"}], "5": [{"t": "فَأَمَّا", "tr": "fa-ammā", "m": "Then as for"}, {"t": "مَنْ", "tr": "man", "m": "(him) who"}, {"t": "أَعْطَىٰ", "tr": "aʿṭā", "m": "gives"}, {"t": "وَٱتَّقَىٰ", "tr": "wa-ittaqā", "m": "and fears"}], "6": [{"t": "وَصَدَّقَ", "tr": "waṣaddaqa", "m": "And believes"}, {"t": "بِٱلْحُسْنَىٰ", "tr": "bil-ḥus'nā", "m": "in the best"}], "7": [{"t": "فَسَنُيَسِّرُهُۥ", "tr": "fasanuyassiruhu", "m": "Then We will ease him"}, {"t": "لِلْيُسْرَىٰ", "tr": "lil'yus'rā", "m": "towards [the] ease"}], "8": [{"t": "وَأَمَّا", "tr": "wa-ammā", "m": "But as for"}, {"t": "مَنۢ", "tr": "man", "m": "(him) who"}, {"t": "بَخِلَ", "tr": "bakhila", "m": "withholds"}, {"t": "وَٱسْتَغْنَىٰ", "tr": "wa-is'taghnā", "m": "and considers himself free from need"}], "9": [{"t": "وَكَذَّبَ", "tr": "wakadhaba", "m": "And denies"}, {"t": "بِٱلْحُسْنَىٰ", "tr": "bil-ḥus'nā", "m": "the best"}], "10": [{"t": "فَسَنُيَسِّرُهُۥ", "tr": "fasanuyassiruhu", "m": "Then We will ease him"}, {"t": "لِلْعُسْرَىٰ", "tr": "lil'ʿus'rā", "m": "towards [the] difficulty"}], "11": [{"t": "وَمَا", "tr": "wamā", "m": "And not"}, {"t": "يُغْنِى", "tr": "yugh'nī", "m": "will avail"}, {"t": "عَنْهُ", "tr": "ʿanhu", "m": "him"}, {"t": "مَالُهُۥٓ", "tr": "māluhu", "m": "his 