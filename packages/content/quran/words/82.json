{"1": [{"t": "إِذَا", "tr": "idhā", "m": "When"}, {"t": "ٱلسَّمَآءُ", "tr": "l-samāu", "m": "the sky"}, {"t": "ٱنفَطَرَتْ", "tr": "infaṭarat", "m": "(is) cleft asunder"}], "2": [{"t": "وَإِذَا", "tr": "wa-idhā", "m": "And when"}, {"t": "ٱلْكَوَاكِبُ", "tr": "l-kawākibu", "m": "the stars"}, {"t": "ٱنتَثَرَتْ", "tr": "intatharat", "m": "scatter"}], "3": [{"t": "وَإِذَا", "tr": "wa-idhā", "m": "And when"}, {"t": "ٱلْبِحَارُ", "tr": "l-biḥāru", "m": "the seas"}, {"t": "فُجِّرَتْ", "tr": "fujjirat", "m": "are made to gush forth"}], "4": [{"t": "وَإِذَا", "tr": "wa-idhā", "m": "And when"}, {"t": "ٱلْقُبُورُ", "tr": "l-qubūru", "m": "the graves"}, {"t": "بُعْثِرَتْ", "tr": "buʿ'thirat", "m": "are overturned"}], "5": [{"t": "عَلِمَتْ", "tr": "ʿalimat", "m": "Will know"}, {"t": "نَفْسٌۭ", "tr": "nafsun", "m": "a soul"}, {"t": "مَّا", "tr": "mā", "m": "what"}, {"t": "قَدَّمَتْ", "tr": "qaddamat", "m": "it has sent forth"}, {"t": "وَأَخَّرَتْ", "tr": "wa-akharat", "m": "and left behind"}], "6": [{"t": "يَـٰٓأَيُّهَا", "tr": "yāayyuhā", "m": "O"}, {"t": "ٱلْإِنسَـٰنُ", "tr": "l-insānu", "m": "man"}, {"t": "مَا", "tr": "mā", "m": "What"}, {"t": "غَرَّكَ", "tr": "gharraka", "m": "has deceived you"}, {"t": "بِرَبِّكَ", "tr": "birabbika", "m": "concerning your Lord"}, {"t": "ٱلْكَرِيمِ", "tr": "l-karīmi", "m": "the Most Noble"}], "7": [{"t": "ٱلَّذِى", "tr": "alladhī", "m": "Who"}, {"t": "خَلَقَكَ", "tr": "khalaqaka", "m": "created you"}, {"t": "فَسَوَّىٰكَ", "tr": "fasawwāka", "m": "then fashioned you"}, {"t": "فَعَدَلَكَ", "tr": "faʿadalaka", "m": "then balanced you"}], "8": [{"t": "فِىٓ", "tr": "fī", "m": "In"}, {"t": "أَىِّ", "tr": "ayyi", "m": "whatever"}, {"t": "صُورَةٍۢ", "tr": "ṣūratin", "m": "form"}, {"t": "مَّا", "tr": "mā", "m": "what"}, {"t": "شَآءَ", "tr": "shāa", "m": "He willed"}, {"t": "رَكَّبَكَ", "tr": "rakkabaka", "m": "He assembled you"}], "9": [{"t": "كَلَّا", "tr": "kallā", "m": "Nay"}, {"t": "بَلْ", "tr": "bal", "m": "But"}, {"t": "تُكَذِّبُونَ", "tr": "tuka