[{"id": 6231, "number": 1, "key": "114:1", "textAr": "قُلْ أَعُوذُ بِرَبِّ ٱلنَّاسِ", "textEn": "Say, \"I seek refuge in the Lord of mankind,", "juz": 30, "page": 604, "hizb": 60, "textTranslit": "Qul a'uzu birabbin naas"}, {"id": 6232, "number": 2, "key": "114:2", "textAr": "مَلِكِ ٱلنَّاسِ", "textEn": "The Sovereign of mankind,", "juz": 30, "page": 604, "hizb": 60, "textTranslit": "Malikin naas"}, {"id": 6233, "number": 3, "key": "114:3", "textAr": "إِلَـٰهِ ٱلنَّاسِ", "textEn": "The God of mankind,", "juz": 30, "page": 604, "hizb": 60, "textTranslit": "Ilaahin naas"}, {"id": 6234, "number": 4, "key": "114:4", "textAr": "مِن شَرِّ ٱلْوَسْوَاسِ ٱلْخَنَّاسِ", "textEn": "From the evil of the retreating whisperer -", "juz": 30, "page": 604, "hizb": 60, "textTranslit": "Min sharril was waasil khannaas"}, {"id": 6235, "number": 5, "key": "114:5", "textAr": "ٱلَّذِى يُوَسْوِسُ فِى صُدُورِ ٱلنَّاسِ", "textEn": "Who whispers [evil] into the breasts of mankind -", "juz": 30, "page": 604, "hizb": 60, "textTranslit": "Al lazee yuwas wisu fee sudoorin naas"}, {"id": 6236, "number": 6, "key": "114:6", "textAr": "مِنَ ٱلْجِنَّةِ وَٱلنَّاسِ", "textEn": "From among the jinn and mankind\".", "juz": 30, "page": 604, "hizb": 60, "textTranslit": "Minal jinnati wan naas"}]