[{"id": 6147, "number": 1, "key": "100:1", "textAr": "وَٱلْعَـٰدِيَـٰتِ ضَبْحًا", "textEn": "By the racers, panting,", "juz": 30, "page": 599, "hizb": 60, "textTranslit": "Wal'aadi yaati dabha"}, {"id": 6148, "number": 2, "key": "100:2", "textAr": "فَٱلْمُورِيَـٰتِ قَدْحًا", "textEn": "And the producers of sparks [when] striking", "juz": 30, "page": 599, "hizb": 60, "textTranslit": "Fal moori yaati qadha"}, {"id": 6149, "number": 3, "key": "100:3", "textAr": "فَٱلْمُغِيرَٰتِ صُبْحًا", "textEn": "And the chargers at dawn,", "juz": 30, "page": 599, "hizb": 60, "textTranslit": "Fal mugheeraati subha"}, {"id": 6150, "number": 4, "key": "100:4", "textAr": "فَأَثَرْنَ بِهِۦ نَقْعًا", "textEn": "Stirring up thereby [clouds of] dust,", "juz": 30, "page": 599, "hizb": 60, "textTranslit": "Fa atharna bihee naq'a"}, {"id": 6151, "number": 5, "key": "100:5", "textAr": "فَوَسَطْنَ بِهِۦ جَمْعًا", "textEn": "Arriving thereby in the center collectively,", "juz": 30, "page": 599, "hizb": 60, "textTranslit": "Fawa satna bihee jam'a"}, {"id": 6152, "number": 6, "key": "100:6", "textAr": "إِنَّ ٱلْإِنسَـٰنَ لِرَبِّهِۦ لَكَنُودٌ", "textEn": "Indeed mankind, to his Lord, is ungrateful.", "juz": 30, "page": 599, "hizb": 60, "textTranslit": "Innal-insana lirabbihee lakanood"}, {"id": 6153, "number": 7, "key": "100:7", "textAr": "وَإِنَّهُۥ عَلَىٰ ذَٰلِكَ لَشَهِيدٌ", "textEn": "And indeed, he is to that a witness.", "juz": 30, "page": 599, "hizb": 60, "textTranslit": "Wa innahu 'alaa zaalika la shaheed"}, {"id": 6154, "number": 8, "key": "100:8", "textAr": "وَإِنَّهُۥ لِحُبِّ ٱلْخَيْرِ لَشَدِيدٌ", "textEn": "And indeed he is, in love of wealth, intense.", "juz": 30, "page": 599, "hizb": 60, "textTranslit": "Wa innahu lihubbil khairi la shadeed"}, {"id": 6155, "number": 9, "key": "100:9", "textAr": "۞ أَفَلَا يَعْلَمُ إِذَا بُعْثِرَ مَا فِى ٱلْقُبُورِ", "textEn": "But does he not know that when the contents of the graves are scattered", "juz": 30, "page": 599, "hizb": 60, "textTranslit": "Afala ya'lamu iza b'uthira ma filquboor"}, {"id": 6156, "number": 10, "key": "100:10", "textAr": "وَحُصِّلَ مَا فِى ٱلصُّدُورِ", "textEn": "And that within the breasts is obtained,", "juz": 30, "page": 600, "hizb": 60, "textTranslit": "Wa hussila maa fis sudoor"}, {"id": 6157, "number": 11, "key": "100:11", "textAr": "إِنَّ رَبَّهُم بِهِمْ يَوْمَئِذٍ لَّخَبِيرٌۢ", "textEn": "Indeed, their Lord with them, that Day, is [fully] Aware.", "juz": 30, "page": 600, "hizb": 60, "textTranslit": "Inna rabbahum bihim yauma 'izil la khabeer"}]