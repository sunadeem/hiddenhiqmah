[{"id": 6205, "number": 1, "key": "108:1", "textAr": "إِنَّآ أَعْطَيْنَـٰكَ ٱلْكَوْثَرَ", "textEn": "Indeed, We have granted you, [O Muḥammad], al-Kawthar.", "juz": 30, "page": 602, "hizb": 60, "textTranslit": "Innaa a'taina kal kauthar"}, {"id": 6206, "number": 2, "key": "108:2", "textAr": "فَصَلِّ لِرَبِّكَ وَٱنْحَرْ", "textEn": "So pray to your Lord and offer sacrifice [to Him alone].", "juz": 30, "page": 602, "hizb": 60, "textTranslit": "Fa salli li rabbika wanhar"}, {"id": 6207, "number": 3, "key": "108:3", "textAr": "إِنَّ شَانِئَكَ هُوَ ٱلْأَبْتَرُ", "textEn": "Indeed, your enemy is the one cut off.", "juz": 30, "page": 602, "hizb": 60, "textTranslit": "Inna shani-aka huwal abtar"}]