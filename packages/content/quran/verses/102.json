[{"id":6169,"number":1,"key":"102:1","textAr":"أَلْهَىٰكُمُ ٱلتَّكَاثُرُ","textEn":"Competition for worldly gains distracts you [from Allah],","juz":30,"page":600,"hizb":60,"textTranslit":"Al haaku mut takathur"},{"id":6170,"number":2,"key":"102:2","textAr":"حَتَّىٰ زُرْتُمُ ٱلْمَقَابِرَ","textEn":"until you come to your graves.","juz":30,"page":600,"hizb":60,"textTranslit":"Hatta zurtumul-maqaabir"},{"id":6171,"number":3,"key":"102:3","textAr":"كَلَّا سَوْفَ تَعْلَمُونَ","textEn":"No indeed! You will come to know.","juz":30,"page":600,"hizb":60,"textTranslit":"Kalla sawfa ta'lamoon"},{"id":6172,"number":4,"key":"102:4","textAr":"ثُمَّ كَلَّا سَوْفَ تَعْلَمُونَ","textEn":"Again no! You will come to know.","juz":30,"page":600,"hizb":60,"textTranslit":"Thumma kalla sawfa ta'lamoon"},{"id":6173,"number":5,"key":"102:5","textAr":"كَلَّا لَوْ تَعْلَمُونَ عِلْمَ ٱلْيَقِينِ","textEn":"No indeed! If only you knew for certain.","juz":30,"page":600,"hizb":60,"textTranslit":"Kalla law ta'lamoona 'ilmal yaqeen"},{"id":6174,"number":6,"key":"102:6","textAr":"لَتَرَوُنَّ ٱلْجَحِيمَ","textEn":"You will surely see the Blazing Fire,","juz":30,"page":600,"hizb":60,"textTranslit":"Latara-wun nal jaheem"},{"id":6175,"number":7,"key":"102:7","textAr":"ثُمَّ لَتَرَوُنَّهَا عَيْنَ ٱلْيَقِينِ","textEn":"Again, you will see it with absolute certainty.","juz":30,"page":600,"hizb":60,"textTranslit":"Thumma latara wunnaha 'ainal yaqeen"},{"id":6176,"number":8,"key":"102:8","textAr":"ثُمَّ لَتُسْـَٔلُنَّ يَوْمَئِذٍ عَنِ ٱلنَّعِيمِ","textEn":"Then on that Day you will surely be asked about your worldly pleasures.","juz":30,"page":600,"hizb":60,"textTranslit":"Thumma latus alunna yauma-izin 'anin na'eem"}]