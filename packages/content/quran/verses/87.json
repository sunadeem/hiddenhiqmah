[{"id":5949,"number":1,"key":"87:1","textAr":"سَبِّحِ ٱسْمَ رَبِّكَ ٱلْأَعْلَى","textEn":"Glorify the name of your Lord, the Most High,","juz":30,"page":591,"hizb":60,"textTranslit":"Sabbihisma Rabbikal A'laa"},{"id":5950,"number":2,"key":"87:2","textAr":"ٱلَّذِى خَلَقَ فَسَوَّىٰ","textEn":"Who created and fashioned in due proportion,","juz":30,"page":591,"hizb":60,"textTranslit":"Allazee khalaqa fasawwaa"},{"id":5951,"number":3,"key":"87:3","textAr":"وَٱلَّذِى قَدَّرَ فَهَدَىٰ","textEn":"and Who determined [the creation] then inspired them,","juz":30,"page":591,"hizb":60,"textTranslit":"Wallazee qaddara fahadaa"},{"id":5952,"number":4,"key":"87:4","textAr":"وَٱلَّذِىٓ أَخْرَجَ ٱلْمَرْعَىٰ","textEn":"and Who brings forth the pasture,","juz":30,"page":591,"hizb":60,"textTranslit":"Wallazeee akhrajal mar'aa"},{"id":5953,"number":5,"key":"87:5","textAr":"فَجَعَلَهُۥ غُثَآءً أَحْوَىٰ","textEn":"then makes it into withered chaff.","juz":30,"page":591,"hizb":60,"textTranslit":"Faja'alahoo ghusaaa'an ahwaa"},{"id":5954,"number":6,"key":"87:6","textAr":"سَنُقْرِئُكَ فَلَا تَنسَىٰٓ","textEn":"We will teach you [the Qur’an], so you will not forget,","juz":30,"page":591,"hizb":60,"textTranslit":"Sanuqri'uka falaa tansaaa"},{"id":5955,"number":7,"key":"87:7","textAr":"إِلَّا مَا شَآءَ ٱللَّهُ ۚ إِنَّهُۥ يَعْلَمُ ٱلْجَهْرَ وَمَا يَخْفَىٰ","textEn":"except what Allah wills, for indeed He knows what is manifest and what is hidden.","juz":30,"page":591,"hizb":60,"textTranslit":"Illaa maa shaaa'al laah; innahoo ya'lamul jahra wa maa yakhfaa"},{"id":5956,"number":8,"key":"87:8","textAr":"وَنُيَسِّرُكَ لِلْيُسْرَىٰ","textEn":"We will guide you to the easy way.","juz":30,"page":591,"hizb":60,"textTranslit":"Wa nu-yassiruka lilyusraa"},{"id":5957,"number":9,"key":"87:9","textAr":"فَذَكِّرْ إِن نَّفَعَتِ ٱلذِّكْرَىٰ","textEn":"So remind, if the reminder should benefit.","juz":30,"page":591,"hizb":60,"textTranslit":"Fazakkir in nafa'atizzikraa"},{"id":5958,"number":10,"key":"87:10","textAr":"سَيَذَّكَّرُ مَن يَخْشَىٰ","textEn":"He who fears Allah will take heed,","juz":30,"page":591,"hizb":60,"textTranslit":"Sa yazzakkaru maiyakhshaa"},{"id":5959,"number":11,"key":"87:11","textAr":"وَيَتَجَنَّبُهَا ٱلْأَشْقَى","textEn":"but the wretched will avoid it,","juz":30,"page":591,"hizb":60,"textTranslit":"Wa yatajannabuhal ashqaa"},{"id":5960,"number":12,"key":"87:12","textAr":"ٱلَّذِى يَصْلَى ٱلنَّارَ ٱلْكُبْرَىٰ","textEn":"who will enter the Great Fire,","juz":30,"page":591,"hizb":60,"textTranslit":"Allazee yaslan Naaral kubraa"},{"id":5961,"number":13,"key":"87:13","textAr":"ثُمَّ لَا يَمُوتُ فِيهَا وَلَا يَحْيَىٰ","textEn":"wherein he will neither die nor live.","juz":30,"page":591,"hizb":60,"textTranslit":"Summa laa yamootu feehaa wa laa yahyaa"},{"id":5962,"number":14,"key":"87:14","textAr":"قَدْ أَفْلَحَ مَن تَزَكَّىٰ","textEn":"Indeed, he who purifies himself will attain success,","juz":30,"page":591,"hizb":60,"textTranslit":"Qad aflaha man tazakkaa"},{"id":5963,"number":15,"key":"87:15","textAr":"وَذَكَرَ ٱسْمَ رَبِّهِۦ فَصَلَّىٰ","textEn":"and remembers his Lord’s Name and prays.","juz":30,"page":591,"hizb":60,"textTranslit":"Wa zakaras ma Rabbihee fasallaa"},{"id":5964,"number":16,"key":"87:16","textAr":"بَلْ تُؤْثِرُونَ ٱلْحَيَوٰةَ ٱلدُّنْيَا","textEn":"But you prefer the life of this world,","juz":30,"page":592,"hizb":60,"textTranslit":"Bal tu'siroonal hayaatad dunyaa"},{"id":5965,"number":17,"key":"87:17","textAr":"وَٱلْـَٔاخِرَةُ خَيْرٌ وَأَبْقَىٰٓ","textEn":"even though the Hereafter is better and more lasting.","juz":30,"page":592,"hizb":60,"textTranslit":"Wal Aakhiratu khairunw wa abqaa"},{"id":5966,"number":18,"key":"87:18","textAr":"إِنَّ هَـٰذَا لَفِى ٱلصُّحُفِ ٱلْأُولَىٰ","textEn":"Indeed, this was in the earlier Scriptures,","juz":30,"page":592,"hizb":60,"textTranslit":"Inna haazaa lafis suhu fil oolaa"},{"id":5967,"number":19,"key":"87:19","textAr":"صُحُفِ إِبْرَٰهِيمَ وَمُوسَىٰ","textEn":"the Scriptures of Abraham and Moses.","juz":30,"page":592,"hizb":60,"textTranslit":"Suhufi Ibraaheema wa Moosaa"}]