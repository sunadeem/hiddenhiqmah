[{"id":5932,"number":1,"key":"86:1","textAr":"وَٱلسَّمَآءِ وَٱلطَّارِقِ","textEn":"By the sky and the night comer –","juz":30,"page":591,"hizb":59,"textTranslit":"Wassamaaa'i wattaariq"},{"id":5933,"number":2,"key":"86:2","textAr":"وَمَآ أَدْرَىٰكَ مَا ٱلطَّارِقُ","textEn":"and how do you know what the night comer is?","juz":30,"page":591,"hizb":59,"textTranslit":"Wa maaa adraaka mattaariq"},{"id":5934,"number":3,"key":"86:3","textAr":"ٱلنَّجْمُ ٱلثَّاقِبُ","textEn":"It is the star of piercing brightness –","juz":30,"page":591,"hizb":59,"textTranslit":"Annajmus saaqib"},{"id":5935,"number":4,"key":"86:4","textAr":"إِن كُلُّ نَفْسٍ لَّمَّا عَلَيْهَا حَافِظٌ","textEn":"there is no soul except that there is a watcher over it.","juz":30,"page":591,"hizb":59,"textTranslit":"In kullu nafsil lammaa 'alaihaa haafiz"},{"id":5936,"number":5,"key":"86:5","textAr":"فَلْيَنظُرِ ٱلْإِنسَـٰنُ مِمَّ خُلِقَ","textEn":"Let man reflect on what he was created from.","juz":30,"page":591,"hizb":59,"textTranslit":"Fal yanzuril insaanu mimma khuliq"},{"id":5937,"number":6,"key":"86:6","textAr":"خُلِقَ مِن مَّآءٍ دَافِقٍ","textEn":"He was created from a spurting fluid,","juz":30,"page":591,"hizb":59,"textTranslit":"Khuliqa mim maaa'in daafiq"},{"id":5938,"number":7,"key":"86:7","textAr":"يَخْرُجُ مِنۢ بَيْنِ ٱلصُّلْبِ وَٱلتَّرَآئِبِ","textEn":"emerging from between the backbone and the ribs.","juz":30,"page":591,"hizb":59,"textTranslit":"Yakhruju mim bainissulbi wat taraaa'ib"},{"id":5939,"number":8,"key":"86:8","textAr":"إِنَّهُۥ عَلَىٰ رَجْعِهِۦ لَقَادِرٌ","textEn":"Indeed, Allah is able to bring him back to life.","juz":30,"page":591,"hizb":59,"textTranslit":"Innahoo 'alaa raj'ihee laqaadir"},{"id":5940,"number":9,"key":"86:9","textAr":"يَوْمَ تُبْلَى ٱلسَّرَآئِرُ","textEn":"On the Day when all secrets will be disclosed,","juz":30,"page":591,"hizb":59,"textTranslit":"Yawma tublas saraaa'ir"},{"id":5941,"number":10,"key":"86:10","textAr":"فَمَا لَهُۥ مِن قُوَّةٍ وَلَا نَاصِرٍ","textEn":"he will then have no power, nor any helper.","juz":30,"page":591,"hizb":59,"textTranslit":"Famaa lahoo min quwwatinw wa laa naasir"},{"id":5942,"number":11,"key":"86:11","textAr":"وَٱلسَّمَآءِ ذَاتِ ٱلرَّجْعِ","textEn":"By the sky and its recurring rain,","juz":30,"page":591,"hizb":59,"textTranslit":"Wassamaaa'i zaatir raj'"},{"id":5943,"number":12,"key":"86:12","textAr":"وَٱلْأَرْضِ ذَاتِ ٱلصَّدْعِ","textEn":"and by the earth that cracks open [with the sprout of plants],","juz":30,"page":591,"hizb":59,"textTranslit":"Wal ardi zaatis sad'"},{"id":5944,"number":13,"key":"86:13","textAr":"إِنَّهُۥ لَقَوْلٌ فَصْلٌ","textEn":"Indeed, this [Qur’an] is a decisive word,","juz":30,"page":591,"hizb":59,"textTranslit":"Innahoo laqawlun fasl"},{"id":5945,"number":14,"key":"86:14","textAr":"وَمَا هُوَ بِٱلْهَزْلِ","textEn":"which is not for amusement.","juz":30,"page":591,"hizb":59,"textTranslit":"Wa maa huwa bil hazl"},{"id":5946,"number":15,"key":"86:15","textAr":"إِنَّهُمْ يَكِيدُونَ كَيْدًا","textEn":"Indeed, they are devising a plan.","juz":30,"page":591,"hizb":59,"textTranslit":"Innahum yakeedoona kaidaa"},{"id":5947,"number":16,"key":"86:16","textAr":"وَأَكِيدُ كَيْدًا","textEn":"I am too devising a plan.","juz":30,"page":591,"hizb":59,"textTranslit":"Wa akeedu kaidaa"},{"id":5948,"number":17,"key":"86:17","textAr":"فَمَهِّلِ ٱلْكَـٰفِرِينَ أَمْهِلْهُمْ رُوَيْدًۢا","textEn":"So bear with the disbelievers, and give them respite for a while.","juz":30,"page":591,"hizb":59,"textTranslit":"Famahhilil kaafireena amhilhum ruwaidaa"}]