[{"id":6091,"number":1,"key":"94:1","textAr":"أَلَمْ نَشْرَحْ لَكَ صَدْرَكَ","textEn":"Have We not reassured your heart for you [O Prophet],","juz":30,"page":596,"hizb":60,"textTranslit":"Alam nashrah laka sadrak"},{"id":6092,"number":2,"key":"94:2","textAr":"وَوَضَعْنَا عَنكَ وِزْرَكَ","textEn":"and relieved you of your burden","juz":30,"page":596,"hizb":60,"textTranslit":"Wa wa d'ana 'anka wizrak"},{"id":6093,"number":3,"key":"94:3","textAr":"ٱلَّذِىٓ أَنقَضَ ظَهْرَكَ","textEn":"that weighed down your back,","juz":30,"page":596,"hizb":60,"textTranslit":"Allazee anqada zahrak"},{"id":6094,"number":4,"key":"94:4","textAr":"وَرَفَعْنَا لَكَ ذِكْرَكَ","textEn":"and raised high your fame for you?","juz":30,"page":596,"hizb":60,"textTranslit":"Wa raf 'ana laka zikrak"},{"id":6095,"number":5,"key":"94:5","textAr":"فَإِنَّ مَعَ ٱلْعُسْرِ يُسْرًا","textEn":"For indeed, with hardship comes ease,","juz":30,"page":596,"hizb":60,"textTranslit":"Fa inna ma'al usri yusra"},{"id":6096,"number":6,"key":"94:6","textAr":"إِنَّ مَعَ ٱلْعُسْرِ يُسْرًا","textEn":"indeed, with hardship comes ease.","juz":30,"page":596,"hizb":60,"textTranslit":"Inna ma'al 'usri yusra"},{"id":6097,"number":7,"key":"94:7","textAr":"فَإِذَا فَرَغْتَ فَٱنصَبْ","textEn":"So whenever you are free, strive in worship,","juz":30,"page":596,"hizb":60,"textTranslit":"Fa iza faragh ta fansab"},{"id":6098,"number":8,"key":"94:8","textAr":"وَإِلَىٰ رَبِّكَ فَٱرْغَب","textEn":"and turn to your Lord in devotion.","juz":30,"page":596,"hizb":60,"textTranslit":"Wa ilaa rabbika far ghab"}]