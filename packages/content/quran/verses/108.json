[{"id":6205,"number":1,"key":"108:1","textAr":"إِنَّآ أَعْطَيْنَـٰكَ ٱلْكَوْثَرَ","textEn":"We have surely given you [O Prophet] al-Kauthar [i.e., abundance],","juz":30,"page":602,"hizb":60,"textTranslit":"Innaa a'taina kal kauthar"},{"id":6206,"number":2,"key":"108:2","textAr":"فَصَلِّ لِرَبِّكَ وَٱنْحَرْ","textEn":"so pray and offer sacrifice to your Lord alone.","juz":30,"page":602,"hizb":60,"textTranslit":"Fa salli li rabbika wanhar"},{"id":6207,"number":3,"key":"108:3","textAr":"إِنَّ شَانِئَكَ هُوَ ٱلْأَبْتَرُ","textEn":"Indeed, the one who hates you is truly cut off [from all goodness].","juz":30,"page":602,"hizb":60,"textTranslit":"Inna shani-aka huwal abtar"}]