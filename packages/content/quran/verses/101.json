[{"id":6158,"number":1,"key":"101:1","textAr":"ٱلْقَارِعَةُ","textEn":"The Striking Calamity!","juz":30,"page":600,"hizb":60,"textTranslit":"Al qaari'ah"},{"id":6159,"number":2,"key":"101:2","textAr":"مَا ٱلْقَارِعَةُ","textEn":"What is the Striking Calamity?","juz":30,"page":600,"hizb":60,"textTranslit":"Mal qaariah"},{"id":6160,"number":3,"key":"101:3","textAr":"وَمَآ أَدْرَىٰكَ مَا ٱلْقَارِعَةُ","textEn":"How do you know what the Striking Calamity is?","juz":30,"page":600,"hizb":60,"textTranslit":"Wa maa adraaka mal qaari'ah"},{"id":6161,"number":4,"key":"101:4","textAr":"يَوْمَ يَكُونُ ٱلنَّاسُ كَٱلْفَرَاشِ ٱلْمَبْثُوثِ","textEn":"On that Day people will be like scattered moths,","juz":30,"page":600,"hizb":60,"textTranslit":"Yauma ya koonun naasu kal farashil mabthooth"},{"id":6162,"number":5,"key":"101:5","textAr":"وَتَكُونُ ٱلْجِبَالُ كَٱلْعِهْنِ ٱلْمَنفُوشِ","textEn":"and the mountains will be like carded wool.","juz":30,"page":600,"hizb":60,"textTranslit":"Wa ta koonul jibalu kal 'ihnil manfoosh"},{"id":6163,"number":6,"key":"101:6","textAr":"فَأَمَّا مَن ثَقُلَتْ مَوَٰزِينُهُۥ","textEn":"Then the one whose scales of good deeds are heavy,","juz":30,"page":600,"hizb":60,"textTranslit":"Fa-amma man thaqulat mawa zeenuh"},{"id":6164,"number":7,"key":"101:7","textAr":"فَهُوَ فِى عِيشَةٍ رَّاضِيَةٍ","textEn":"will have a pleasant life.","juz":30,"page":600,"hizb":60,"textTranslit":"Fahuwa fee 'ishatir raadiyah"},{"id":6165,"number":8,"key":"101:8","textAr":"وَأَمَّا مَنْ خَفَّتْ مَوَٰزِينُهُۥ","textEn":"But the one whose scales of good deeds are light,","juz":30,"page":600,"hizb":60,"textTranslit":"Wa amma man khaffat mawa zeenuh"},{"id":6166,"number":9,"key":"101:9","textAr":"فَأُمُّهُۥ هَاوِيَةٌ","textEn":"his abode will be the abyss.","juz":30,"page":600,"hizb":60,"textTranslit":"Fa-ummuhu haawiyah"},{"id":6167,"number":10,"key":"101:10","textAr":"وَمَآ أَدْرَىٰكَ مَا هِيَهْ","textEn":"And how do you know what it is?","juz":30,"page":600,"hizb":60,"textTranslit":"Wa maa adraaka maa hiyah"},{"id":6168,"number":11,"key":"101:11","textAr":"نَارٌ حَامِيَةٌۢ","textEn":"It is a Blazing Fire.","juz":30,"page":600,"hizb":60,"textTranslit":"Naarun hamiyah"}]