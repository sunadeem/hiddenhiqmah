[{"id":5801,"number":1,"key":"81:1","textAr":"إِذَا ٱلشَّمْسُ كُوِّرَتْ","textEn":"When the sun is wrapped up in darkness,","juz":30,"page":586,"hizb":59,"textTranslit":"Izash shamsu kuwwirat"},{"id":5802,"number":2,"key":"81:2","textAr":"وَإِذَا ٱلنُّجُومُ ٱنكَدَرَتْ","textEn":"and when the stars fall down,","juz":30,"page":586,"hizb":59,"textTranslit":"Wa izan nujoomun kadarat"},{"id":5803,"number":3,"key":"81:3","textAr":"وَإِذَا ٱلْجِبَالُ سُيِّرَتْ","textEn":"and when the mountains are set in motion,","juz":30,"page":586,"hizb":59,"textTranslit":"Wa izal jibaalu suyyirat"},{"id":5804,"number":4,"key":"81:4","textAr":"وَإِذَا ٱلْعِشَارُ عُطِّلَتْ","textEn":"and when pregnant camels are left unattended,","juz":30,"page":586,"hizb":59,"textTranslit":"Wa izal 'ishaaru 'uttilat"},{"id":5805,"number":5,"key":"81:5","textAr":"وَإِذَا ٱلْوُحُوشُ حُشِرَتْ","textEn":"and when wild beasts are gathered,","juz":30,"page":586,"hizb":59,"textTranslit":"Wa izal wuhooshu hushirat"},{"id":5806,"number":6,"key":"81:6","textAr":"وَإِذَا ٱلْبِحَارُ سُجِّرَتْ","textEn":"and when the seas are set on fire,","juz":30,"page":586,"hizb":59,"textTranslit":"Wa izal bihaaru sujjirat"},{"id":5807,"number":7,"key":"81:7","textAr":"وَإِذَا ٱلنُّفُوسُ زُوِّجَتْ","textEn":"and when the souls are sorted,","juz":30,"page":586,"hizb":59,"textTranslit":"Wa izan nufoosu zuwwijat"},{"id":5808,"number":8,"key":"81:8","textAr":"وَإِذَا ٱلْمَوْءُۥدَةُ سُئِلَتْ","textEn":"and when the baby girl buried alive is asked,","juz":30,"page":586,"hizb":59,"textTranslit":"Wa izal maw'oodatu su'ilat"},{"id":5809,"number":9,"key":"81:9","textAr":"بِأَىِّ ذَنۢبٍ قُتِلَتْ","textEn":"for what crime she was killed,","juz":30,"page":586,"hizb":59,"textTranslit":"Bi ayyi zambin qutilat"},{"id":5810,"number":10,"key":"81:10","textAr":"وَإِذَا ٱلصُّحُفُ نُشِرَتْ","textEn":"and when records of deeds are spread open,","juz":30,"page":586,"hizb":59,"textTranslit":"Wa izas suhufu nushirat"},{"id":5811,"number":11,"key":"81:11","textAr":"وَإِذَا ٱلسَّمَآءُ كُشِطَتْ","textEn":"and when the sky is stripped away,","juz":30,"page":586,"hizb":59,"textTranslit":"Wa izas samaaa'u kushitat"},{"id":5812,"number":12,"key":"81:12","textAr":"وَإِذَا ٱلْجَحِيمُ سُعِّرَتْ","textEn":"and when the Blazing Fire is flared up,","juz":30,"page":586,"hizb":59,"textTranslit":"Wa izal jaheemu su'-'irat"},{"id":5813,"number":13,"key":"81:13","textAr":"وَإِذَا ٱلْجَنَّةُ أُزْلِفَتْ","textEn":"and when Paradise is brought near –","juz":30,"page":586,"hizb":59,"textTranslit":"Wa izal jannatu uzlifat"},{"id":5814,"number":14,"key":"81:14","textAr":"عَلِمَتْ نَفْسٌ مَّآ أَحْضَرَتْ","textEn":"then every soul will know what it has brought about.","juz":30,"page":586,"hizb":59,"textTranslit":"'Alimat nafsum maaa ahdarat"},{"id":5815,"number":15,"key":"81:15","textAr":"فَلَآ أُقْسِمُ بِٱلْخُنَّسِ","textEn":"I swear by the receding stars,","juz":30,"page":586,"hizb":59,"textTranslit":"Falaaa uqsimu bil khunnas"},{"id":5816,"number":16,"key":"81:16","textAr":"ٱلْجَوَارِ ٱلْكُنَّسِ","textEn":"that rise and hide,","juz":30,"page":586,"hizb":59,"textTranslit":"Al jawaaril kunnas"},{"id":5817,"number":17,"key":"81:17","textAr":"وَٱلَّيْلِ إِذَا عَسْعَسَ","textEn":"and by the night as it departs,","juz":30,"page":586,"hizb":59,"textTranslit":"Wallaili izaa 'as'as"},{"id":5818,"number":18,"key":"81:18","textAr":"وَٱلصُّبْحِ إِذَا تَنَفَّسَ","textEn":"and by the day as it breaks –","juz":30,"page":586,"hizb":59,"textTranslit":"Wassubhi izaa tanaffas"},{"id":5819,"number":19,"key":"81:19","textAr":"إِنَّهُۥ لَقَوْلُ رَسُولٍ كَرِيمٍ","textEn":"Indeed, this [Qur’an] is a word conveyed by a noble angel-messenger.","juz":30,"page":586,"hizb":59,"textTranslit":"Innahoo laqawlu rasoolin kareem"},{"id":5820,"number":20,"key":"81:20","textAr":"ذِى قُوَّةٍ عِندَ ذِى ٱلْعَرْشِ مَكِينٍ","textEn":"extremely powerful, highly revered by the Lord of the Throne,","juz":30,"page":586,"hizb":59,"textTranslit":"Zee quwwatin 'inda zil 'arshi makeen"},{"id":5821,"number":21,"key":"81:21","textAr":"مُّطَاعٍ ثَمَّ أَمِينٍ","textEn":"obeyed there [by other angels] and trustworthy.","juz":30,"page":586,"hizb":59,"textTranslit":"Mutaa'in samma ameen"},{"id":5822,"number":22,"key":"81:22","textAr":"وَمَا صَاحِبُكُم بِمَجْنُونٍ","textEn":"Your fellow [i.e., the Prophet] is not a madman.","juz":30,"page":586,"hizb":59,"textTranslit":"Wa maa saahibukum bimajnoon"},{"id":5823,"number":23,"key":"81:23","textAr":"وَلَقَدْ رَءَاهُ بِٱلْأُفُقِ ٱلْمُبِينِ","textEn":"He indeed saw him [i.e., Gabriel] on the clear horizon.","juz":30,"page":586,"hizb":59,"textTranslit":"Wa laqad ra aahu bilufuqil mubeen"},{"id":5824,"number":24,"key":"81:24","textAr":"وَمَا هُوَ عَلَى ٱلْغَيْبِ بِضَنِينٍ","textEn":"He does not withhold [knowledge of] the unseen.","juz":30,"page":586,"hizb":59,"textTranslit":"Wa maa huwa 'alal ghaibi bidaneen"},{"id":5825,"number":25,"key":"81:25","textAr":"وَمَا هُوَ بِقَوْلِ شَيْطَـٰنٍ رَّجِيمٍ","textEn":"This [Qur’an] is not the word of an accursed devil.","juz":30,"page":586,"hizb":59,"textTranslit":"Wa maa huwa biqawli shaitaanir rajeem"},{"id":5826,"number":26,"key":"81:26","textAr":"فَأَيْنَ تَذْهَبُونَ","textEn":"So which way are you going?","juz":30,"page":586,"hizb":59,"textTranslit":"Fa ayna tazhaboon"},{"id":5827,"number":27,"key":"81:27","textAr":"إِنْ هُوَ إِلَّا ذِكْرٌ لِّلْعَـٰلَمِينَ","textEn":"It is but a reminder to the worlds,","juz":30,"page":586,"hizb":59,"textTranslit":"In huwa illaa zikrul lil'aalameen"},{"id":5828,"number":28,"key":"81:28","textAr":"لِمَن شَآءَ مِنكُمْ أَن يَسْتَقِيمَ","textEn":"for those among you who wish to take the straight path.","juz":30,"page":586,"hizb":59,"textTranslit":"Liman shaaa'a minkum ai yastaqeem"},{"id":5829,"number":29,"key":"81:29","textAr":"وَمَا تَشَآءُونَ إِلَّآ أَن يَشَآءَ ٱللَّهُ رَبُّ ٱلْعَـٰلَمِينَ","textEn":"But you cannot wish except by the Will of Allah, the Lord of the worlds.","juz":30,"page":586,"hizb":59,"textTranslit":"Wa maa tashaaa'oona illaaa ai yashaaa 'al laahu Rabbul 'Aalameen"}]