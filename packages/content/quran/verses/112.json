[{"id":6222,"number":1,"key":"112:1","textAr":"قُلْ هُوَ ٱللَّهُ أَحَدٌ","textEn":"Say: “He is Allah, the One;","juz":30,"page":604,"hizb":60,"textTranslit":"Qul huwal laahu ahad"},{"id":6223,"number":2,"key":"112:2","textAr":"ٱللَّهُ ٱلصَّمَدُ","textEn":"Allah, the Eternal Refuge.","juz":30,"page":604,"hizb":60,"textTranslit":"Allah hus-samad"},{"id":6224,"number":3,"key":"112:3","textAr":"لَمْ يَلِدْ وَلَمْ يُولَدْ","textEn":"He neither begets nor is He begotten,","juz":30,"page":604,"hizb":60,"textTranslit":"Lam yalid wa lam yoolad"},{"id":6225,"number":4,"key":"112:4","textAr":"وَلَمْ يَكُن لَّهُۥ كُفُوًا أَحَدٌۢ","textEn":"and there is none comparable to Him.”","juz":30,"page":604,"hizb":60,"textTranslit":"Wa lam yakul-lahu kufuwan ahad"}]