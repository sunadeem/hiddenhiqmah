[{"id":6180,"number":1,"key":"104:1","textAr":"وَيْلٌ لِّكُلِّ هُمَزَةٍ لُّمَزَةٍ","textEn":"Woe to every backbiter and slanderer,","juz":30,"page":601,"hizb":60,"textTranslit":"Wai lul-li kulli hu mazatil-lumaza"},{"id":6181,"number":2,"key":"104:2","textAr":"ٱلَّذِى جَمَعَ مَالًا وَعَدَّدَهُۥ","textEn":"who amasses wealth and counts it over and again,","juz":30,"page":601,"hizb":60,"textTranslit":"Al-lazi jama'a maalaw wa'addadah"},{"id":6182,"number":3,"key":"104:3","textAr":"يَحْسَبُ أَنَّ مَالَهُۥٓ أَخْلَدَهُۥ","textEn":"thinking that his wealth will make him live forever.","juz":30,"page":601,"hizb":60,"textTranslit":"Yahsabu anna maalahu akhladah"},{"id":6183,"number":4,"key":"104:4","textAr":"كَلَّا ۖ لَيُنۢبَذَنَّ فِى ٱلْحُطَمَةِ","textEn":"No indeed! He will surely be cast into the Crushing Fire,","juz":30,"page":601,"hizb":60,"textTranslit":"Kalla layum ba zanna fil hutamah"},{"id":6184,"number":5,"key":"104:5","textAr":"وَمَآ أَدْرَىٰكَ مَا ٱلْحُطَمَةُ","textEn":"and how do you know what the Crushing Fire is?","juz":30,"page":601,"hizb":60,"textTranslit":"Wa maa adraaka mal-hutamah"},{"id":6185,"number":6,"key":"104:6","textAr":"نَارُ ٱللَّهِ ٱلْمُوقَدَةُ","textEn":"It is the kindled Fire of Allah,","juz":30,"page":601,"hizb":60,"textTranslit":"Narul laahil-mooqada"},{"id":6186,"number":7,"key":"104:7","textAr":"ٱلَّتِى تَطَّلِعُ عَلَى ٱلْأَفْـِٔدَةِ","textEn":"which reaches the hearts.","juz":30,"page":601,"hizb":60,"textTranslit":"Al latee tat tali'u 'alalafidah"},{"id":6187,"number":8,"key":"104:8","textAr":"إِنَّهَا عَلَيْهِم مُّؤْصَدَةٌ","textEn":"It will be closed down upon them,","juz":30,"page":601,"hizb":60,"textTranslit":"Innaha 'alaihim moosada"},{"id":6188,"number":9,"key":"104:9","textAr":"فِى عَمَدٍ مُّمَدَّدَةٍۭ","textEn":"locked with towering columns.","juz":30,"page":601,"hizb":60,"textTranslit":"Fee 'amadim-mu mad dadah"}]