[{"id":6059,"number":1,"key":"92:1","textAr":"وَٱلَّيْلِ إِذَا يَغْشَىٰ","textEn":"By the night when it covers,","juz":30,"page":595,"hizb":60,"textTranslit":"Wallaili izaa yaghshaa"},{"id":6060,"number":2,"key":"92:2","textAr":"وَٱلنَّهَارِ إِذَا تَجَلَّىٰ","textEn":"and by the day when it appears,","juz":30,"page":595,"hizb":60,"textTranslit":"Wannahaari izaa tajalla"},{"id":6061,"number":3,"key":"92:3","textAr":"وَمَا خَلَقَ ٱلذَّكَرَ وَٱلْأُنثَىٰٓ","textEn":"and by His creation of male and female,","juz":30,"page":595,"hizb":60,"textTranslit":"Wa maa khalaqaz zakara wal unthaa"},{"id":6062,"number":4,"key":"92:4","textAr":"إِنَّ سَعْيَكُمْ لَشَتَّىٰ","textEn":"surely your efforts are divergent.","juz":30,"page":595,"hizb":60,"textTranslit":"Inna sa'yakum lashattaa"},{"id":6063,"number":5,"key":"92:5","textAr":"فَأَمَّا مَنْ أَعْطَىٰ وَٱتَّقَىٰ","textEn":"As for the one who gives in charity and fears Allah,","juz":30,"page":595,"hizb":60,"textTranslit":"Fa ammaa man a'taa wattaqaa"},{"id":6064,"number":6,"key":"92:6","textAr":"وَصَدَّقَ بِٱلْحُسْنَىٰ","textEn":"and truly believes in the best reward,","juz":30,"page":595,"hizb":60,"textTranslit":"Wa saddaqa bil husnaa"},{"id":6065,"number":7,"key":"92:7","textAr":"فَسَنُيَسِّرُهُۥ لِلْيُسْرَىٰ","textEn":"We will make easy for him the way of salvation.","juz":30,"page":595,"hizb":60,"textTranslit":"Fasanu yassiruhoo lilyusraa"},{"id":6066,"number":8,"key":"92:8","textAr":"وَأَمَّا مَنۢ بَخِلَ وَٱسْتَغْنَىٰ","textEn":"But as for the one who is miserly and deems himself self-sufficient,","juz":30,"page":595,"hizb":60,"textTranslit":"Wa ammaa mam bakhila wastaghnaa"},{"id":6067,"number":9,"key":"92:9","textAr":"وَكَذَّبَ بِٱلْحُسْنَىٰ","textEn":"and denies the best reward,","juz":30,"page":595,"hizb":60,"textTranslit":"Wa kazzaba bil husnaa"},{"id":6068,"number":10,"key":"92:10","textAr":"فَسَنُيَسِّرُهُۥ لِلْعُسْرَىٰ","textEn":"We will make easy for him the way of perdition.","juz":30,"page":595,"hizb":60,"textTranslit":"Fasanu yassiruhoo lil'usraa"},{"id":6069,"number":11,"key":"92:11","textAr":"وَمَا يُغْنِى عَنْهُ مَالُهُۥٓ إِذَا تَرَدَّىٰٓ","textEn":"His wealth will be of no avail to him when he tumbles [into Hell].","juz":30,"page":595,"hizb":60,"textTranslit":"Wa maa yughnee 'anhu maaluhooo izaa taraddaa"},{"id":6070,"number":12,"key":"92:12","textAr":"إِنَّ عَلَيْنَا لَلْهُدَىٰ","textEn":"Indeed, it is upon Us to show the right way,","juz":30,"page":595,"hizb":60,"textTranslit":"Inna 'alainaa lal hudaa"},{"id":6071,"number":13,"key":"92:13","textAr":"وَإِنَّ لَنَا لَلْـَٔاخِرَةَ وَٱلْأُولَىٰ","textEn":"and surely to Us belong the Hereafter and the present life.","juz":30,"page":595,"hizb":60,"textTranslit":"Wa inna lanaa lal Aakhirata wal oolaa"},{"id":6072,"number":14,"key":"92:14","textAr":"فَأَنذَرْتُكُمْ نَارًا تَلَظَّىٰ","textEn":"So I warn you of a raging Fire,","juz":30,"page":595,"hizb":60,"textTranslit":"Fa anzartukum naaran talazzaa"},{"id":6073,"number":15,"key":"92:15","textAr":"لَا يَصْلَىٰهَآ إِلَّا ٱلْأَشْقَى","textEn":"none will enter it except the most wretched,","juz":30,"page":596,"hizb":60,"textTranslit":"Laa yaslaahaaa illal ashqaa"},{"id":6074,"number":16,"key":"92:16","textAr":"ٱلَّذِى كَذَّبَ وَتَوَلَّىٰ","textEn":"who denied and turned away.","juz":30,"page":596,"hizb":60,"textTranslit":"Allazee kazzaba wa tawallaa"},{"id":6075,"number":17,"key":"92:17","textAr":"وَسَيُجَنَّبُهَا ٱلْأَتْقَى","textEn":"But the most righteous will be saved from it,","juz":30,"page":596,"hizb":60,"textTranslit":"Wa sa yujannnabuhal atqaa"},{"id":6076,"number":18,"key":"92:18","textAr":"ٱلَّذِى يُؤْتِى مَالَهُۥ يَتَزَكَّىٰ","textEn":"who spends his wealth to purify himself,","juz":30,"page":596,"hizb":60,"textTranslit":"Allazee yu'tee maalahoo yatazakkaa"},{"id":6077,"number":19,"key":"92:19","textAr":"وَمَا لِأَحَدٍ عِندَهُۥ مِن نِّعْمَةٍ تُجْزَىٰٓ","textEn":"not in return for someone’s favors,","juz":30,"page":596,"hizb":60,"textTranslit":"Wa maa li ahadin 'indahoo min ni'matin tujzaaa"},{"id":6078,"number":20,"key":"92:20","textAr":"إِلَّا ٱبْتِغَآءَ وَجْهِ رَبِّهِ ٱلْأَعْلَىٰ","textEn":"but to seek the pleasure of his Lord, the Most High.","juz":30,"page":596,"hizb":60,"textTranslit":"Illab tighaaa'a wajhi rabbihil a 'laa"},{"id":6079,"number":21,"key":"92:21","textAr":"وَلَسَوْفَ يَرْضَىٰ","textEn":"He will surely be well pleased.","juz":30,"page":596,"hizb":60,"textTranslit":"Wa lasawfa yardaa"}]