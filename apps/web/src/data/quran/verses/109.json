[{"id": 6208, "number": 1, "key": "109:1", "textAr": "قُلْ يَـٰٓأَيُّهَا ٱلْكَـٰفِرُونَ", "textEn": "Say, \"O disbelievers,", "juz": 30, "page": 603, "hizb": 60, "textTranslit": "Qul yaa-ai yuhal kaafiroon"}, {"id": 6209, "number": 2, "key": "109:2", "textAr": "لَآ أَعْبُدُ مَا تَعْبُدُونَ", "textEn": "I do not worship what you worship.", "juz": 30, "page": 603, "hizb": 60, "textTranslit": "Laa a'budu ma t'abudoon"}, {"id": 6210, "number": 3, "key": "109:3", "textAr": "وَلَآ أَنتُمْ عَـٰبِدُونَ مَآ أَعْبُدُ", "textEn": "Nor are you worshippers of what I worship.", "juz": 30, "page": 603, "hizb": 60, "textTranslit": "Wa laa antum 'aabidoona maa a'bud"}, {"id": 6211, "number": 4, "key": "109:4", "textAr": "وَلَآ أَنَا۠ عَابِدٌ مَّا عَبَدتُّمْ", "textEn": "Nor will I be a worshipper of what you worship.", "juz": 30, "page": 603, "hizb": 60, "textTranslit": "Wa laa ana 'abidum maa 'abattum"}, {"id": 6212, "number": 5, "key": "109:5", "textAr": "وَلَآ أَنتُمْ عَـٰبِدُونَ مَآ أَعْبُدُ", "textEn": "Nor will you be worshippers of what I worship.", "juz": 30, "page": 603, "hizb": 60, "textTranslit": "Wa laa antum 'aabidoona ma a'bud"}, {"id": 6213, "number": 6, "key": "109:6", "textAr": "لَكُمْ دِينُكُمْ وَلِىَ دِينِ", "textEn": "For you is your religion, and for me is my religion.\"", "juz": 30, "page": 603, "hizb": 60, "textTranslit": "Lakum deenukum wa liya deen."}]