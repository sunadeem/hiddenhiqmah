{"1": [{"t": "لِإِيلَـٰفِ", "tr": "liīlāfi", "m": "For (the) familiarity"}, {"t": "قُرَيْشٍ", "tr": "qurayshin", "m": "(of the) Quraish"}], "2": [{"t": "إِۦلَـٰفِهِمْ", "tr": "īlāfihim", "m": "Their familiarity"}, {"t": "رِحْلَةَ", "tr": "riḥ'lata", "m": "(with the) journey"}, {"t": "ٱلشِّتَآءِ", "tr": "l-shitāi", "m": "(of) winter"}, {"t": "وَٱلصَّيْفِ", "tr": "wal-ṣayfi", "m": "and summer"}], "3": [{"t": "فَلْيَعْبُدُوا۟", "tr": "falyaʿbudū", "m": "So let them worship"}, {"t": "رَبَّ", "tr": "rabba", "m": "(the) Lord"}, {"t": "هَـٰذَا", "tr": "hādhā", "m": "(of) this"}, {"t": "ٱلْبَيْتِ", "tr": "l-bayti", "m": "House"}], "4": [{"t": "ٱلَّذِىٓ", "tr": "alladhī", "m": "The One Who"}, {"t": "أَطْعَمَهُم", "tr": "aṭʿamahum", "m": "feeds them"}, {"t": "مِّن", "tr": "min", "m": "[from]"}, {"t": "جُوعٍۢ", "tr": "jūʿin", "m": "(against) hunger"}, {"t": "وَءَامَنَهُم", "tr": "waāmanahum", "m": "and gives them security"}, {"t": "مِّنْ", "tr": "min", "m": "from"}, {"t": "خَوْفٍۭ", "tr": "khawfin", "m": "fear"}]}