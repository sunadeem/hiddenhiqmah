{"1": [{"t": "سَبِّحِ", "tr": "sabbiḥi", "m": "Glorify"}, {"t": "ٱسْمَ", "tr": "is'ma", "m": "(the) name"}, {"t": "رَبِّكَ", "tr": "rabbika", "m": "(of) your Lord"}, {"t": "ٱلْأَعْلَى", "tr": "l-aʿlā", "m": "the Most High"}], "2": [{"t": "ٱلَّذِى", "tr": "alladhī", "m": "The One Who"}, {"t": "خَلَقَ", "tr": "khalaqa", "m": "created"}, {"t": "فَسَوَّىٰ", "tr": "fasawwā", "m": "then proportioned"}], "3": [{"t": "وَٱلَّذِى", "tr": "wa-alladhī", "m": "And the One Who"}, {"t": "قَدَّرَ", "tr": "qaddara", "m": "measured"}, {"t": "فَهَدَىٰ", "tr": "fahadā", "m": "then guided"}], "4": [{"t": "وَٱلَّذِىٓ", "tr": "wa-alladhī", "m": "And the One Who"}, {"t": "أَخْرَجَ", "tr": "akhraja", "m": "brings forth"}, {"t": "ٱلْمَرْعَىٰ", "tr": "l-marʿā", "m": "the pasture"}], "5": [{"t": "فَجَعَلَهُۥ", "tr": "fajaʿalahu", "m": "And then makes it"}, {"t": "غُثَآءً", "tr": "ghuthāan", "m": "stubble"}, {"t": "أَحْوَىٰ", "tr": "aḥwā", "m": "dark"}], "6": [{"t": "سَنُقْرِئُكَ", "tr": "sanuq'ri-uka", "m": "We will make you recite"}, {"t": "فَلَا", "tr": "falā", "m": "so not"}, {"t": "تَنسَىٰٓ", "tr": "tansā", "m": "you will forget"}], "7": [{"t": "إِلَّا", "tr": "illā", "m": "Except"}, {"t": "مَا", "tr": "mā", "m": "what"}, {"t": "شَآءَ", "tr": "shāa", "m": "wills"}, {"t": "ٱللَّهُ ۚ", "tr": "l-lahu", "m": "Allah"}, {"t": "إِنَّهُۥ", "tr": "innahu", "m": "Indeed, He"}, {"t": "يَعْلَمُ", "tr": "yaʿlamu", "m": "knows"}, {"t": "ٱلْجَهْرَ", "tr": "l-jahra", "m": "the manifest"}, {"t": "وَمَا", "tr": "wamā", "m": "and what"}, {"t": "يَخْفَىٰ", "tr": "yakhfā", "m": "is hidden"}], "8": [{"t": "وَنُيَسِّرُكَ", "tr": "wanuyassiruka", "m": "And We will ease you"}, {"t": "لِلْيُسْرَىٰ", "tr": "lil'yus'rā", "m": "to the ease"}], "9": [{"t": "فَذَكِّرْ", "tr": "fadhakkir", "m": "So remind"}, {"t": "إِن", "tr": "in", "m": "if"}, {"t": "نَّفَعَتِ", "tr": "nafaʿati", "m": "benefits"}, {"t": "ٱلذِّكْرَىٰ", "tr": "l-dhik'rā", "m": "the reminder"}], "10": [{"t": "سَيَذَّكَّرُ", "tr": "sayadhakkaru", "m": "He